---
const { title, icon } = Astro.props;
---

<header class="header glass">
  <div class="header-left">
    <button id="menu-toggle" class="menu-toggle" aria-label="Buka navigasi">
      <i class="fa-solid fa-bars"></i>
    </button>
    <div class="page-title">
      <div class="title-icon">
        <i class={`fa-solid ${icon}`}></i>
      </div>
      <h2>{title}</h2>
    </div>
  </div>
  
  <div class="profile-container">
    <div class="user-profile" id="user-profile-trigger">
      <div class="user-info">
        <span class="user-name">Tim IT RS</span>
        <span class="user-role">RSU SEBENING KASIH</span>
      </div>
      <div class="avatar">
        <img src="https://ui-avatars.com/api/?name=Tim+IT&background=C0392B&color=fff&rounded=true&bold=true" alt="Avatar" />
      </div>
    </div>
    
    <!-- Profile Dropdown Menu -->
    <div class="profile-dropdown" id="profile-dropdown">
      <div class="dropdown-header">
        <div class="dropdown-avatar-wrapper">
          <img src="https://ui-avatars.com/api/?name=Tim+IT&background=C0392B&color=fff&rounded=true&bold=true&size=128" alt="Avatar" class="dropdown-avatar" />
          <span class="status-badge pulse"></span>
        </div>
        <div class="dropdown-user-details">
          <h3>Tim IT RS</h3>
          <span class="dropdown-user-role">PDE LANCAR ABADI JAYA</span>
          <span class="dropdown-user-email">admin@rsusebeningkasih.com</span>
        </div>
      </div>

      <div class="dropdown-section">
        <div class="section-title">Informasi Faskes</div>
        <div class="faskes-info-grid">
          <div class="info-item">
            <span class="info-label">Nama Faskes</span>
            <span class="info-value">RSU Sebening Kasih</span>
          </div>
          <div class="info-item">
            <span class="info-label">Kepemilikan</span>
            <span class="info-value">Swasta</span>
          </div>
          <div class="info-item">
            <span class="info-label">Fasilitas Kesehatan</span>
            <span class="info-value">Rumah Sakit</span>
          </div>
          <div class="info-item">
            <span class="info-label">Status Integrasi</span>
            <span class="info-value status-connected">
              <i class="fa-solid fa-circle-check"></i> Terhubung
            </span>
          </div>
        </div>
      </div>

    </div>
  </div>
</header>

<style>
  .header {
    height: 72px;
    padding: 0 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(255, 255, 255, 0.85);
    flex-shrink: 0;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    flex: 1;
  }

  /* Hamburger — hidden on desktop */
  .menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    min-width: 40px;
    border: 1.5px solid var(--color-border-secondary);
    background: white;
    border-radius: 10px;
    cursor: pointer;
    color: var(--color-text-main);
    font-size: 15px;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .menu-toggle:hover {
    background: var(--color-primary-light);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .page-title {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .title-icon {
    width: 36px;
    height: 36px;
    min-width: 36px;
    background: white;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    border: 1px solid var(--color-border);
  }

  .title-icon i {
    color: var(--color-primary);
    font-size: 16px;
  }

  .page-title h2 {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .profile-container {
    position: relative;
    display: inline-block;
  }

  .user-profile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 6px 16px 6px 6px;
    background: white;
    border-radius: 30px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .user-profile:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-soft);
  }

  .user-profile:active {
    transform: translateY(1px);
    box-shadow: none;
    opacity: 0.8;
  }

  .user-profile.active {
    border-color: var(--color-primary);
    background: var(--color-primary-light);
  }

  /* ── Dropdown Menu ───────────────────────────────────────── */
  .profile-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    width: 320px;
    max-width: calc(100vw - 32px);
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border-secondary);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.08), 0 8px 16px -6px rgba(0, 0, 0, 0.05), 0 0 1px rgba(0, 0, 0, 0.15);
    opacity: 0;
    transform: translateY(-10px) scale(0.95);
    visibility: hidden;
    pointer-events: none;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 50;
    overflow: hidden;
  }

  .profile-dropdown.active {
    opacity: 1;
    transform: translateY(0) scale(1);
    visibility: visible;
    pointer-events: auto;
  }

  .dropdown-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: linear-gradient(135deg, rgba(192, 57, 43, 0.03) 0%, rgba(192, 57, 43, 0.08) 100%);
    border-bottom: 1px solid var(--color-border);
  }

  .dropdown-avatar-wrapper {
    position: relative;
    width: 54px;
    height: 54px;
    flex-shrink: 0;
  }

  .dropdown-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 2px solid white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .dropdown-avatar-wrapper .status-badge {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 12px;
    height: 12px;
    background: #10b981;
    border: 2px solid white;
    border-radius: 50%;
  }

  .dropdown-avatar-wrapper .status-badge.pulse::after {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid #10b981;
    animation: statusPulse 2s infinite ease-out;
  }

  @keyframes statusPulse {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  .dropdown-user-details {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .dropdown-user-details h3 {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.3;
  }

  .dropdown-user-role {
    font-size: 11.5px;
    color: var(--color-primary);
    font-weight: 700;
    margin-top: 1px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .dropdown-user-email {
    font-size: 11px;
    color: var(--color-text-muted);
    word-break: break-all;
    margin-top: 2px;
  }

  .dropdown-section {
    padding: 16px 20px;
  }

  .section-title {
    font-size: 10.5px;
    font-weight: 700;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  .faskes-info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px 14px;
  }

  .info-item {
    display: flex;
    flex-direction: column;
  }

  .info-label {
    font-size: 10px;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .info-value {
    font-size: 12px;
    color: var(--color-text-main);
    font-weight: 700;
    margin-top: 2px;
  }

  .info-value.status-connected {
    color: #166534;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }


  .user-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    margin-right: 4px;
  }

  .user-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-main);
    line-height: 1.2;
  }

  .user-role {
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .avatar {
    width: 32px;
    height: 32px;
    order: -1;
    flex-shrink: 0;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
  }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .header {
      padding: 0 16px;
      height: 60px;
    }

    .menu-toggle {
      display: flex;
    }

    .page-title h2 {
      font-size: 15px;
    }

    .title-icon {
      width: 32px;
      height: 32px;
      min-width: 32px;
    }

    .user-info {
      display: none;
    }

    .user-profile {
      padding: 5px;
      border-radius: 50%;
    }
  }

  @media (max-width: 420px) {
    .page-title h2 {
      font-size: 13px;
    }
  }
</style>

<script>
  function initProfileMenu() {
    const trigger = document.getElementById('user-profile-trigger');
    const dropdown = document.getElementById('profile-dropdown');

    if (!trigger || !dropdown) return;

    // Prevent duplicate event listeners if the header is persisted
    if (trigger.dataset.hasDropdownListener) return;
    trigger.dataset.hasDropdownListener = 'true';

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isActive = dropdown.classList.toggle('active');
      trigger.classList.toggle('active', isActive);
    });

    // Close dropdown on click outside
    document.addEventListener('click', (e) => {
      if (!trigger.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
        dropdown.classList.remove('active');
        trigger.classList.remove('active');
      }
    });

    // Close dropdown on ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdown.classList.remove('active');
        trigger.classList.remove('active');
      }
    });
  }

  // Setup on page load and view transitions
  document.addEventListener('astro:page-load', initProfileMenu);
</script>
