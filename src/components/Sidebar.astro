---
const { currentPath } = Astro.props;

// Normalisasi path: buang trailing slash supaya cocok di Vercel
// (Astro static memakai trailingSlash 'ignore', mis. "/igd/" vs "/igd").
const stripSlash = (p: string) => (p.length > 1 && p.endsWith("/") ? p.slice(0, -1) : p);
const here = stripSlash(currentPath ?? "/");
const isActive = (path: string) => stripSlash(path) === here;

const menuItems = [
  { path: "/", title: "Rawat Jalan (Rajal)", icon: "fa-hospital-user" },
  { path: "/igd", title: "IGD", icon: "fa-truck-medical" },
  { path: "/ranap", title: "Rawat Inap (Ranap)", icon: "fa-bed-pulse" },
  { path: "/questionnaire", title: "Questionnaire", icon: "fa-list-check" },
  { path: "/immunization", title: "Immunization", icon: "fa-syringe" },
  { path: "/resources", title: "Resource Pelengkap", icon: "fa-puzzle-piece" },
];

const resourceItems = [
  { path: "/organisasi", title: "Organization", icon: "fa-sitemap" },
  { path: "/location", title: "Location", icon: "fa-location-dot" },
  { path: "/practitioner", title: "Practitioner", icon: "fa-user-doctor" },
];
---

<aside id="sidebar" class="sidebar glass">
  <button id="sidebar-close" class="sidebar-close" aria-label="Tutup menu">
    <i class="fa-solid fa-xmark"></i>
  </button>

  <div class="sidebar-header">
    <img src="/satusehat.png" alt="SatuSehat Logo" class="sidebar-logo" />
    <div class="logo-text">
      <h1>Integrasi</h1>
      <h2>SATUSEHAT</h2>
    </div>
  </div>

  <div class="menu-section">
    <div class="menu-title">MODUL UTAMA</div>
    <ul class="menu-list">
      {
        menuItems.map((item) => (
          <li class="menu-item">
            <a
              href={item.path}
              class={`menu-link ${isActive(item.path) ? "active" : ""}`}
            >
              <i class={`fa-solid ${item.icon}`} />
              <span>{item.title}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="menu-section">
    <div class="menu-title">Resources - Prerequisites</div>
    <ul class="menu-list">
      {
        resourceItems.map((item) => (
          <li class="menu-item">
            <a
              href={item.path}
              class={`menu-link ${isActive(item.path) ? "active" : ""}`}
            >
              <i class={`fa-solid ${item.icon}`} />
              <span>{item.title}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="sidebar-footer">
    <div class="version-info">
      <span>Versi 1.3.0</span>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    width: 280px;
    height: 100vh;
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.4);
    z-index: 20;
    padding: 24px 16px;
    flex-shrink: 0;
    transition:
      width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      padding 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-bottom: 32px;
    margin-bottom: 24px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  }

  .sidebar-logo {
    height: 44px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .logo-text h1 {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.5px;
    line-height: 1;
  }

  .logo-text h2 {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.2;
  }

  .menu-section {
    margin-bottom: 32px;
  }

  .menu-title {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 1.5px;
    margin-bottom: 12px;
    padding-left: 12px;
  }

  .menu-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .menu-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    color: var(--color-text-main);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .menu-link i {
    font-size: 16px;
    width: 20px;
    text-align: center;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .menu-link:hover {
    background: rgba(255, 255, 255, 0.6);
    transform: translateX(4px);
  }

  .menu-link.active {
    background: white;
    color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(255, 255, 255, 1);
  }

  .menu-link.active i {
    color: var(--color-primary);
  }

  /* Close button — hidden on desktop */
  .sidebar-close {
    display: none;
    position: absolute;
    top: 14px;
    right: 14px;
    width: 32px;
    height: 32px;
    border: 1.5px solid var(--color-border-secondary);
    background: white;
    border-radius: 8px;
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: 14px;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .sidebar-close:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: var(--color-primary-light);
  }

  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      z-index: 100;
      transform: translateX(-100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      overflow-y: auto;
      width: 280px;
      padding-top: 20px;
    }

    .sidebar-close {
      display: flex;
    }

    .sidebar-header {
      padding-right: 48px;
    }
  }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px dashed rgba(0, 0, 0, 0.08);
    text-align: center;
  }

  .version-info {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.5px;
  }
</style>
