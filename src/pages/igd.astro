---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IGD" pageTitle="IGD" icon="fa-truck-medical">
  <div class="wrap">
  <div class="header">
    <h2><i class="fa-solid fa-heart-pulse" style="color: #C0392B;"></i> Alur SATUSEHAT Instalasi Gawat Darurat (IGD)</h2>
    <div class="sub">Lengkap per Aktor · Klik resource untuk detail implementasi · Tab untuk fokus per fase · class Encounter: EMER</div>
  </div>

  <div class="tab-bar">
    <button class="tab on" onclick="showPhase('all',this)"><i class="fa-solid fa-border-all"></i> Semua</button>
    <button class="tab" onclick="showPhase('triase',this)"><i class="fa-solid fa-truck-medical"></i> Triase</button>
    <button class="tab" onclick="showPhase('asesmen',this)"><i class="fa-solid fa-stethoscope"></i> Asesmen Awal</button>
    <button class="tab" onclick="showPhase('penanganan',this)"><i class="fa-solid fa-user-nurse"></i> Penanganan</button>
    <button class="tab" onclick="showPhase('farmasi',this)"><i class="fa-solid fa-pills"></i> Farmasi</button>
    <button class="tab" onclick="showPhase('lab',this)"><i class="fa-solid fa-flask-vial"></i> Laboratorium</button>
    <button class="tab" onclick="showPhase('radiologi',this)"><i class="fa-solid fa-x-ray"></i> Radiologi</button>
    <button class="tab" onclick="showPhase('disposisi',this)"><i class="fa-solid fa-person-walking-arrow-right"></i> Disposisi</button>
  </div>

  <div class="legend">
    <div class="leg"><div class="leg-dot pulse" style="background:#922B21"></div>IGD/Triase</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#1E8449"></div>Perawat IGD</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#6C3483"></div>Dokter IGD</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#117A65"></div>Farmasi</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#1A5276"></div>Laboratorium</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#7B241C"></div>Radiologi</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#C0392B"></div>Wajib</div>
    <div class="leg"><div class="leg-dot" style="background:#888"></div>Opsional</div>
  </div>

  <div class="scroll">
  <svg id="svg" width="1100" viewBox="0 0 1100 2080" role="img">
    <title>Alur SATUSEHAT IGD lengkap</title>
    <defs>
      <marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
        <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </marker>
    </defs>

    <!-- ACTORS: Pasien=54, Triase=162, Perawat=272, Dokter=382, Farmasi=497, Lab=612, Rad=724, SS=960 -->
    <rect x="10" y="8" width="86" height="38" rx="7" fill="#2C3E50"/>
    <text x="53" y="31" text-anchor="middle" font-size="11" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Pasien /</text>
    <text x="53" y="43" text-anchor="middle" font-size="10" fill="#BDC3C7" font-family="var(--font-sans)">Keluarga</text>

    <rect x="112" y="8" width="100" height="38" rx="7" fill="#922B21"/>
    <text x="162" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Triase IGD</text>
    <text x="162" y="40" text-anchor="middle" font-size="9" fill="#F1948A" font-family="var(--font-sans)">(Perawat Triase)</text>

    <rect x="222" y="8" width="100" height="38" rx="7" fill="#1E8449"/>
    <text x="272" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Perawat IGD</text>
    <text x="272" y="40" text-anchor="middle" font-size="9" fill="#A9DFBF" font-family="var(--font-sans)">(Ruang Tindakan)</text>

    <rect x="334" y="8" width="98" height="38" rx="7" fill="#6C3483"/>
    <text x="383" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Dokter IGD</text>
    <text x="383" y="40" text-anchor="middle" font-size="9" fill="#D7BDE2" font-family="var(--font-sans)">(Jaga / Spesialis)</text>

    <rect x="449" y="8" width="96" height="38" rx="7" fill="#117A65"/>
    <text x="497" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Farmasi IGD</text>
    <text x="497" y="40" text-anchor="middle" font-size="9" fill="#A2D9CE" font-family="var(--font-sans)">(Depo IGD)</text>

    <rect x="562" y="8" width="100" height="38" rx="7" fill="#1A5276"/>
    <text x="612" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Laboratorium</text>
    <text x="612" y="40" text-anchor="middle" font-size="9" fill="#AED6F1" font-family="var(--font-sans)">(Lab Cito)</text>

    <rect x="676" y="8" width="100" height="38" rx="7" fill="#7B241C"/>
    <text x="726" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Radiologi</text>
    <text x="726" y="40" text-anchor="middle" font-size="9" fill="#F1948A" font-family="var(--font-sans)">(Cito/PACS)</text>

    <rect x="848" y="8" width="230" height="38" rx="7" fill="#C0392B"/>
    <text x="963" y="24" text-anchor="middle" font-size="11" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">SATUSEHAT Platform</text>
    <text x="963" y="38" text-anchor="middle" font-size="9" fill="#F1948A" font-family="var(--font-sans)">+ NIDR (untuk Radiologi)</text>

    <!-- Lifelines -->
    <line x1="53"  y1="46" x2="53"  y2="2072" stroke="#2C3E50" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="162" y1="46" x2="162" y2="2072" stroke="#922B21" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="272" y1="46" x2="272" y2="2072" stroke="#1E8449" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="383" y1="46" x2="383" y2="2072" stroke="#6C3483" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="497" y1="46" x2="497" y2="2072" stroke="#117A65" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="612" y1="46" x2="612" y2="2072" stroke="#1A5276" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="726" y1="46" x2="726" y2="2072" stroke="#7B241C" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="963" y1="46" x2="963" y2="2072" stroke="#C0392B" stroke-width="1.1" stroke-dasharray="3 4" opacity=".28"/>

    <!-- ===== FASE 1: TRIASE ===== -->
    <rect x="8" y="58" width="1080" height="19" rx="3" fill="#922B21" opacity=".13"/>
    <text x="14" y="71" font-size="10" font-weight="500" fill="#922B21" font-family="var(--font-sans)">FASE 1 — Kedatangan &amp; Triase IGD</text>

    <text x="56" y="96" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Masuk IGD</text>
    <line x1="53" y1="100" x2="155" y2="100" stroke="#922B21" stroke-width="1.5" marker-end="url(#ar)"/>

    <!-- Encounter IGD -->
    <g class="rn" data-id="enc_igd" data-phase="triase" style="cursor:pointer">
      <rect x="120" y="106" width="957" height="44" rx="5" fill="#E74C3C" opacity=".12" stroke="#E74C3C" stroke-width="1.3" stroke-opacity=".6"/>
      <text x="129" y="123" font-size="11" font-weight="500" fill="#922B21" font-family="var(--font-sans)">1. Encounter — Kunjungan IGD</text>
      <text x="129" y="138" font-size="10" fill="#7B241C" font-family="var(--font-sans)">status: arrived | class: EMER | serviceType: 117 (Emergency) | location: ruang triase</text>
      <rect x="934" y="112" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="957" y="123" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="162" y1="150" x2="954" y2="150" stroke="#E74C3C" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="555" y="146" text-anchor="middle" font-size="9" fill="#E74C3C" font-family="var(--font-sans)">POST /Encounter → simpan encounter-id (dipakai seluruh IGD)</text>
    </g>

    <!-- ClinicalImpression Triase -->
    <g class="rn" data-id="clinical_triase" data-phase="triase" style="cursor:pointer">
      <rect x="120" y="160" width="957" height="44" rx="5" fill="#E74C3C" opacity=".1" stroke="#E74C3C" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="129" y="177" font-size="11" font-weight="500" fill="#922B21" font-family="var(--font-sans)">2. ClinicalImpression — Triase IGD</text>
      <text x="129" y="192" font-size="10" fill="#7B241C" font-family="var(--font-sans)">Kategori triase: P1/P2/P3/P4 (merah/kuning/hijau/hitam) | keluhan utama | LOINC 11283-9</text>
      <rect x="934" y="166" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="957" y="177" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="162" y1="204" x2="954" y2="204" stroke="#E74C3C" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="555" y="200" text-anchor="middle" font-size="9" fill="#E74C3C" font-family="var(--font-sans)">POST /ClinicalImpression → simpan ci-id</text>
    </g>

    <!-- Observation Tanda Vital Cito -->
    <g class="rn" data-id="obs_triase" data-phase="triase" style="cursor:pointer">
      <rect x="120" y="214" width="957" height="44" rx="5" fill="#E74C3C" opacity=".1" stroke="#E74C3C" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="129" y="231" font-size="11" font-weight="500" fill="#922B21" font-family="var(--font-sans)">3. Observation — Tanda Vital Cito (Saat Triase)</text>
      <text x="129" y="246" font-size="10" fill="#7B241C" font-family="var(--font-sans)">Tensi, nadi, suhu, RR, SpO2, GCS, skala nyeri | kode LOINC | 1 Obs per parameter</text>
      <rect x="934" y="220" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="957" y="231" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="162" y1="258" x2="954" y2="258" stroke="#E74C3C" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="555" y="254" text-anchor="middle" font-size="9" fill="#E74C3C" font-family="var(--font-sans)">POST /Observation (multiple, cito)</text>
    </g>

    <!-- ===== FASE 2: ASESMEN AWAL ===== -->
    <rect x="8" y="272" width="1080" height="19" rx="3" fill="#1E8449" opacity=".13"/>
    <text x="14" y="285" font-size="10" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">FASE 2 — Asesmen Awal Medis (Perawat &amp; Dokter IGD)</text>

    <text x="165" y="308" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Asesmen awal pasien</text>
    <line x1="162" y1="312" x2="265" y2="312" stroke="#1E8449" stroke-width="1.5" marker-end="url(#ar)"/>

    <g class="rn" data-id="allergy_igd" data-phase="asesmen" style="cursor:pointer">
      <rect x="230" y="318" width="847" height="42" rx="5" fill="#27AE60" opacity=".1" stroke="#27AE60" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="239" y="334" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">4. AllergyIntolerance — Riwayat Alergi</text>
      <text x="239" y="349" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Alergi obat/makanan | NKA jika tidak ada | dikumpulkan dari pasien/keluarga saat asesmen</text>
      <rect x="934" y="324" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="957" y="334" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="272" y1="360" x2="954" y2="360" stroke="#27AE60" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
    </g>

    <g class="rn" data-id="fmhist_igd" data-phase="asesmen" style="cursor:pointer">
      <rect x="230" y="368" width="847" height="40" rx="5" fill="#27AE60" opacity=".07" stroke="#27AE60" stroke-width="1" stroke-opacity=".35" stroke-dasharray="4 3"/>
      <text x="239" y="384" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">5. FamilyMemberHistory — Riwayat Keluarga</text>
      <text x="239" y="398" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Penyakit herediter relevan | dikumpulkan dari keluarga | opsional di IGD</text>
      <rect x="921" y="374" width="66" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="954" y="385" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="272" y1="408" x2="954" y2="408" stroke="#27AE60" stroke-width="1" marker-end="url(#ar)" stroke-dasharray="3 4" stroke-opacity=".5"/>
    </g>

    <g class="rn" data-id="medstat_igd" data-phase="asesmen" style="cursor:pointer">
      <rect x="230" y="416" width="847" height="40" rx="5" fill="#27AE60" opacity=".07" stroke="#27AE60" stroke-width="1" stroke-opacity=".35" stroke-dasharray="4 3"/>
      <text x="239" y="432" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">6. MedicationStatement — Obat yang Sedang Dikonsumsi</text>
      <text x="239" y="446" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Obat rutin/swamedikasi sebelum masuk IGD | informasi penting untuk tindakan emergency</text>
      <rect x="921" y="422" width="66" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="954" y="433" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="272" y1="456" x2="954" y2="456" stroke="#27AE60" stroke-width="1" marker-end="url(#ar)" stroke-dasharray="3 4" stroke-opacity=".5"/>
    </g>

    <!-- ===== FASE 3: PENANGANAN ===== -->
    <rect x="8" y="468" width="1080" height="19" rx="3" fill="#6C3483" opacity=".13"/>
    <text x="14" y="481" font-size="10" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">FASE 3 — Penanganan &amp; Pemeriksaan Dokter IGD</text>

    <text x="386" y="504" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Penanganan &amp; pemeriksaan</text>
    <line x1="383" y1="508" x2="275" y2="508" stroke="#6C3483" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="3 3" stroke-opacity=".5"/>

    <!-- Update Encounter in-progress -->
    <g class="rn" data-id="enc_inprogress" data-phase="penanganan" style="cursor:pointer">
      <rect x="120" y="514" width="957" height="42" rx="5" fill="#4A90D9" opacity=".1" stroke="#4A90D9" stroke-width="1.2" stroke-opacity=".5" stroke-dasharray="5 3"/>
      <text x="129" y="530" font-size="11" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">7. Encounter — Update Status In-Progress (Mulai Penanganan)</text>
      <text x="129" y="545" font-size="10" fill="#2874A6" font-family="var(--font-sans)">PUT Encounter | status: in-progress | location: ruang tindakan/resusitasi | period.start diupdate</text>
      <rect x="921" y="520" width="66" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="954" y="531" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="162" y1="556" x2="954" y2="556" stroke="#4A90D9" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".6"/>
      <text x="555" y="552" text-anchor="middle" font-size="9" fill="#4A90D9" font-family="var(--font-sans)">PUT /Encounter/&#123;id&#125; → status: in-progress</text>
    </g>

    <!-- Condition Diagnosa Awal -->
    <g class="rn" data-id="cond_igd" data-phase="penanganan" style="cursor:pointer">
      <rect x="120" y="564" width="957" height="44" rx="5" fill="#9B6BBE" opacity=".12" stroke="#9B6BBE" stroke-width="1.3" stroke-opacity=".55"/>
      <text x="129" y="581" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">8. Condition — Diagnosa Awal / Kerja IGD</text>
      <text x="129" y="596" font-size="10" fill="#7D3C98" font-family="var(--font-sans)">ICD-10 wajib | verificationStatus: provisional (bisa berubah) | dikirim SEBELUM Procedure</text>
      <rect x="934" y="570" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="957" y="581" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="383" y1="608" x2="954" y2="608" stroke="#9B6BBE" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="668" y="604" text-anchor="middle" font-size="9" fill="#9B6BBE" font-family="var(--font-sans)">POST /Condition → simpan condition-id</text>
    </g>

    <!-- Procedure Tindakan Cito/Resusitasi -->
    <g class="rn" data-id="proc_igd" data-phase="penanganan" style="cursor:pointer">
      <rect x="120" y="618" width="957" height="44" rx="5" fill="#9B6BBE" opacity=".12" stroke="#9B6BBE" stroke-width="1.3" stroke-opacity=".55"/>
      <text x="129" y="635" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">9. Procedure — Tindakan Cito / Resusitasi</text>
      <text x="129" y="650" font-size="10" fill="#7D3C98" font-family="var(--font-sans)">Resusitasi, stabilisasi, tindakan cito | ICD-9-CM | reasonReference → Condition ID | emergency flag</text>
      <rect x="934" y="624" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="957" y="635" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="383" y1="662" x2="954" y2="662" stroke="#9B6BBE" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="668" y="658" text-anchor="middle" font-size="9" fill="#9B6BBE" font-family="var(--font-sans)">POST /Procedure (setelah Condition)</text>
    </g>

    <!-- Observation Monitoring -->
    <g class="rn" data-id="obs_monitor" data-phase="penanganan" style="cursor:pointer">
      <rect x="120" y="672" width="957" height="40" rx="5" fill="#27AE60" opacity=".08" stroke="#27AE60" stroke-width="1" stroke-opacity=".4" stroke-dasharray="4 3"/>
      <text x="129" y="688" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">10. Observation — Monitoring Berkala Selama di IGD</text>
      <text x="129" y="702" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Re-asesmen tanda vital berkala | GCS, EWS (Early Warning Score) | monitor respons terapi</text>
      <rect x="921" y="678" width="66" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="954" y="689" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="272" y1="712" x2="954" y2="712" stroke="#27AE60" stroke-width="1" marker-end="url(#ar)" stroke-dasharray="3 4" stroke-opacity=".5"/>
      <text x="614" y="708" text-anchor="middle" font-size="9" fill="#27AE60" font-family="var(--font-sans)" opacity=".8">POST /Observation (berkala selama di IGD)</text>
    </g>

    <!-- ===== FASE 4A: FARMASI IGD ===== -->
    <rect x="8" y="724" width="1080" height="19" rx="3" fill="#117A65" opacity=".14"/>
    <text x="14" y="737" font-size="10" font-weight="500" fill="#117A65" font-family="var(--font-sans)">FASE 4A — Farmasi Depo IGD (Order &amp; Pemberian Obat Cito)</text>

    <text x="386" y="760" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Order obat cito</text>
    <line x1="383" y1="764" x2="490" y2="764" stroke="#117A65" stroke-width="1.5" marker-end="url(#ar)"/>

    <g class="rn" data-id="medrq_igd" data-phase="farmasi" style="cursor:pointer">
      <rect x="453" y="770" width="624" height="44" rx="5" fill="#1ABC9C" opacity=".1" stroke="#1ABC9C" stroke-width="1.3" stroke-opacity=".52"/>
      <text x="462" y="787" font-size="11" font-weight="500" fill="#117A65" font-family="var(--font-sans)">11. MedicationRequest — Resep Cito / Obat Emergency</text>
      <text x="462" y="802" font-size="10" fill="#0E6655" font-family="var(--font-sans)">priority: urgent | Medication dalam contained | route: IV/IM/SC | dosageInstruction</text>
      <rect x="934" y="776" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="957" y="787" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="497" y1="814" x2="954" y2="814" stroke="#1ABC9C" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
