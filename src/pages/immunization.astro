---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Immunization" pageTitle="Immunization" icon="fa-syringe">
  <div class="wrap">
  <div class="header">
    <h2><i class="fa-solid fa-syringe" style="color: #0E6655;"></i> Immunization — Posisi di Rajal, IGD &amp; Ranap + Penanggung Jawab</h2>
    <div class="sub">Resource Immunization mencatat pemberian vaksin/imunisasi. Klik tiap blok untuk detail field &amp; PIC pengisian di SATUSEHAT.</div>
  </div>

  <div class="tab-bar">
    <button class="tab on" onclick="showPhase('all',this)"><i class="fa-solid fa-border-all"></i> Semua Modul</button>
    <button class="tab" onclick="showPhase('rajal',this)"><i class="fa-solid fa-hospital-user"></i> Rajal</button>
    <button class="tab" onclick="showPhase('igd',this)"><i class="fa-solid fa-truck-medical"></i> IGD</button>
    <button class="tab" onclick="showPhase('ranap',this)"><i class="fa-solid fa-bed-pulse"></i> Ranap</button>
  </div>

  <div class="legend">
    <div class="leg"><div class="leg-dot pulse" style="background:#1F618D"></div>Pendaftaran / Admisi</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#1E8449"></div>Perawat</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#6C3483"></div>Dokter</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#0E6655"></div>Imunisasi / Vaksinator</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#C0392B"></div>SATUSEHAT</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#C0392B"></div>WAJIB</div>
    <div class="leg"><div class="leg-dot" style="background:#888"></div>Opsional</div>
  </div>

  <div class="scroll">
  <svg id="svg" width="1060" viewBox="0 0 1060 1760" role="img">
    <title>Posisi Immunization di Rajal IGD Ranap SATUSEHAT</title>
    <defs>
      <marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
        <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </marker>
    </defs>

    <!-- ============================================================ -->
    <!-- MODUL RAJAL -->
    <!-- ============================================================ -->
    <rect x="8" y="8" width="1044" height="22" rx="4" fill="#1F618D" opacity=".14"/>
    <text x="14" y="23" font-size="11" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">MODUL RAWAT JALAN (RAJAL) — Posisi Immunization</text>

    <!-- Actor boxes Rajal -->
    <rect x="52"  y="36" width="90" height="34" rx="6" fill="#1F618D"/>
    <text x="97"  y="55" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Pendaftaran</text>

    <rect x="172" y="36" width="90" height="34" rx="6" fill="#1E8449"/>
    <text x="217" y="51" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Perawat</text>
    <text x="217" y="63" text-anchor="middle" font-size="8" fill="#A9DFBF" font-family="var(--font-sans)">(Poli)</text>

    <rect x="292" y="36" width="90" height="34" rx="6" fill="#6C3483"/>
    <text x="337" y="55" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Dokter (Poli)</text>

    <rect x="412" y="36" width="110" height="34" rx="6" fill="#0E6655"/>
    <text x="467" y="51" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Vaksinator</text>
    <text x="467" y="63" text-anchor="middle" font-size="8" fill="#A2D9CE" font-family="var(--font-sans)">(Perawat/Bidan)</text>

    <rect x="800" y="36" width="240" height="34" rx="6" fill="#C0392B"/>
    <text x="920" y="55" text-anchor="middle" font-size="10" font-weight="500" fill="#fff" font-family="var(--font-sans)">SATUSEHAT Platform</text>

    <!-- Lifelines Rajal -->
    <line x1="97"  y1="70" x2="97"  y2="360" stroke="#1F618D" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="217" y1="70" x2="217" y2="360" stroke="#1E8449" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="337" y1="70" x2="337" y2="360" stroke="#6C3483" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="467" y1="70" x2="467" y2="360" stroke="#0E6655" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="920" y1="70" x2="920" y2="360" stroke="#C0392B" stroke-width="1" stroke-dasharray="3 4" opacity=".25"/>

    <!-- Encounter Rajal konteks -->
    <rect x="60" y="78" width="970" height="32" rx="4" fill="#4A90D9" opacity=".08" stroke="#4A90D9" stroke-width="1" stroke-opacity=".4"/>
    <text x="68" y="94" font-size="10" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">Encounter (AMB, arrived→finished) — anchor semua resource rajal</text>
    <line x1="97" y1="110" x2="912" y2="110" stroke="#4A90D9" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".5"/>

    <!-- IMM Rajal 1: Imunisasi Rutin / Program Nasional -->
    <g class="rn" data-id="imm_rutin_rajal" data-mod="rajal" style="cursor:pointer">
      <rect x="415" y="118" width="625" height="46" rx="5" fill="#0E6655" opacity=".1" stroke="#0E6655" stroke-width="1.3" stroke-opacity=".55"/>
      <text x="423" y="135" font-size="11" font-weight="500" fill="#0E6655" font-family="var(--font-sans)">IMM-1 Rajal: Imunisasi Rutin / Program Nasional (Poli Imunisasi/KIA)</text>
      <text x="423" y="150" font-size="10" fill="#0B5345" font-family="var(--font-sans)">PIC: Vaksinator (Perawat/Bidan) | dilakukan di poli imunisasi atau KIA setelah ada order dokter</text>
      <rect x="895" y="124" width="86" height="14" rx="3" fill="#C0392B" opacity=".18"/>
      <text x="938" y="135" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB*</text>
      <line x1="467" y1="164" x2="912" y2="164" stroke="#0E6655" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="690" y="160" text-anchor="middle" font-size="9" fill="#0E6655" font-family="var(--font-sans)">POST /Immunization (setelah Encounter)</text>
    </g>

    <!-- IMM Rajal 2: Imunisasi Catch-up / Tambahan -->
    <g class="rn" data-id="imm_catchup_rajal" data-mod="rajal" style="cursor:pointer">
      <rect x="415" y="172" width="625" height="46" rx="5" fill="#0E6655" opacity=".06" stroke="#0E6655" stroke-width="1" stroke-opacity=".4" stroke-dasharray="4 3"/>
      <text x="423" y="189" font-size="11" font-weight="500" fill="#0E6655" font-family="var(--font-sans)">IMM-2 Rajal: Imunisasi Catch-up / Booster / Tambahan</text>
      <text x="423" y="204" font-size="10" fill="#0B5345" font-family="var(--font-sans)">PIC: Vaksinator | untuk imunisasi yang terlewat atau booster dewasa (HPV, influenza, tetanus, dll)</text>
      <rect x="895" y="178" width="86" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="938" y="189" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="467" y1="218" x2="912" y2="218" stroke="#0E6655" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".7"/>
      <text x="690" y="214" text-anchor="middle" font-size="9" fill="#0E6655" font-family="var(--font-sans)">POST /Immunization (status: completed)</text>
    </g>

    <!-- IMM Rajal 3: Imunisasi Tidak Diberikan -->
    <g class="rn" data-id="imm_refused_rajal" data-mod="rajal" style="cursor:pointer">
      <rect x="415" y="226" width="625" height="46" rx="5" fill="#7B241C" opacity=".06" stroke="#7B241C" stroke-width="1" stroke-opacity=".35" stroke-dasharray="4 3"/>
      <text x="423" y="243" font-size="11" font-weight="500" fill="#7B241C" font-family="var(--font-sans)">IMM-3 Rajal: Imunisasi Tidak Diberikan (Tolak / Kontraindikasi)</text>
      <text x="423" y="258" font-size="10" fill="#641E16" font-family="var(--font-sans)">PIC: Dokter / Vaksinator | dokumentasikan penolakan atau kontraindikasi secara eksplisit</text>
      <rect x="895" y="232" width="86" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="938" y="243" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="467" y1="272" x2="912" y2="272" stroke="#7B241C" stroke-width="1.1" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".6"/>
      <text x="690" y="268" text-anchor="middle" font-size="9" fill="#7B241C" font-family="var(--font-sans)">POST /Immunization (status: not-done + statusReason)</text>
    </g>

    <!-- Note Rajal -->
    <rect x="60" y="282" width="970" height="70" rx="5" fill="none" stroke="#e2e8f0" stroke-width=".8"/>
    <text x="70" y="298" font-size="9" font-weight="500" fill="#0E6655" font-family="var(--font-sans)">Catatan Rajal: * WAJIB jika pasien mendapat imunisasi dalam kunjungan tersebut (program nasional BIAN, imunisasi rutin anak, dll)</text>
    <text x="70" y="312" font-size="9" fill="#475569" font-family="var(--font-sans)">Urutan di Rajal: Encounter (arrived) → Dokter order → Vaksinator berikan vaksin → POST /Immunization → Encounter (finished)</text>
    <text x="70" y="326" font-size="9" fill="#475569" font-family="var(--font-sans)">PIC: Vaksinator (Perawat/Bidan terlatih) yang memberikan vaksin fisik. Dokter sebagai penanggung jawab (performer.actor.reference)</text>
    <text x="70" y="340" font-size="9" fill="#C0392B" font-family="var(--font-sans)">Penting: Imunisasi yang ditolak pasien atau ada kontraindikasi TETAP harus dicatat dengan status: not-done</text>

    <!-- ============================================================ -->
    <!-- MODUL IGD -->
    <!-- ============================================================ -->
    <rect x="8" y="368" width="1044" height="22" rx="4" fill="#922B21" opacity=".14"/>
    <text x="14" y="383" font-size="11" font-weight="500" fill="#922B21" font-family="var(--font-sans)">MODUL IGD — Posisi Immunization</text>

    <!-- Actor boxes IGD -->
    <rect x="52"  y="396" width="90" height="34" rx="6" fill="#922B21"/>
    <text x="97"  y="411" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Triase IGD</text>
    <text x="97"  y="423" text-anchor="middle" font-size="8" fill="#F1948A" font-family="var(--font-sans)">(Perawat Triase)</text>

    <rect x="172" y="396" width="90" height="34" rx="6" fill="#1E8449"/>
    <text x="217" y="411" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Perawat IGD</text>
    <text x="217" y="423" text-anchor="middle" font-size="8" fill="#A9DFBF" font-family="var(--font-sans)">(Ruang Tindakan)</text>

    <rect x="292" y="396" width="90" height="34" rx="6" fill="#6C3483"/>
    <text x="337" y="411" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Dokter IGD</text>
    <text x="337" y="423" text-anchor="middle" font-size="8" fill="#D7BDE2" font-family="var(--font-sans)">(Jaga)</text>

    <rect x="412" y="396" width="110" height="34" rx="6" fill="#0E6655"/>
    <text x="467" y="411" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Vaksinator IGD</text>
    <text x="467" y="423" text-anchor="middle" font-size="8" fill="#A2D9CE" font-family="var(--font-sans)">(Perawat/Dokter)</text>

    <rect x="800" y="396" width="240" height="34" rx="6" fill="#C0392B"/>
    <text x="920" y="415" text-anchor="middle" font-size="10" font-weight="500" fill="#fff" font-family="var(--font-sans)">SATUSEHAT Platform</text>

    <!-- Lifelines IGD -->
    <line x1="97"  y1="430" x2="97"  y2="660" stroke="#922B21" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="217" y1="430" x2="217" y2="660" stroke="#1E8449" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="337" y1="430" x2="337" y2="660" stroke="#6C3483" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="467" y1="430" x2="467" y2="660" stroke="#0E6655" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="920" y1="430" x2="920" y2="660" stroke="#C0392B" stroke-width="1" stroke-dasharray="3 4" opacity=".25"/>

    <!-- Encounter IGD konteks -->
    <rect x="60" y="438" width="970" height="32" rx="4" fill="#E74C3C" opacity=".07" stroke="#E74C3C" stroke-width="1" stroke-opacity=".4"/>
    <text x="68" y="454" font-size="10" font-weight="500" fill="#922B21" font-family="var(--font-sans)">Encounter (EMER, arrived→in-progress→finished) — anchor semua resource IGD</text>
    <line x1="97" y1="470" x2="912" y2="470" stroke="#E74C3C" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".5"/>

    <!-- IMM IGD 1: Profilaksis Pasca Pajanan (PEP) -->
    <g class="rn" data-id="imm_pep_igd" data-mod="igd" style="cursor:pointer">
      <rect x="60" y="478" width="970" height="46" rx="5" fill="#E74C3C" opacity=".11" stroke="#E74C3C" stroke-width="1.3" stroke-opacity=".55"/>
      <text x="68" y="495" font-size="11" font-weight="500" fill="#922B21" font-family="var(--font-sans)">IMM-1 IGD: Profilaksis Pasca Pajanan (PEP) — Tetanus, Rabies, Hepatitis B</text>
      <text x="68" y="510" font-size="10" fill="#7B241C" font-family="var(--font-sans)">PIC: Dokter IGD / Perawat IGD | luka tusuk, gigitan binatang, pajanan darah — berdasarkan status vaksinasi sebelumnya</text>
      <rect x="895" y="484" width="86" height="14" rx="3" fill="#C0392B" opacity=".18"/>
      <text x="938" y="495" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB*</text>
      <line x1="467" y1="524" x2="912" y2="524" stroke="#E74C3C" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="690" y="520" text-anchor="middle" font-size="9" fill="#E74C3C" font-family="var(--font-sans)">POST /Immunization (PEP) — bersamaan atau segera setelah tindakan</text>
    </g>

    <!-- IMM IGD 2: Imunisasi Darurat / Wabah -->
    <g class="rn" data-id="imm_darurat_igd" data-mod="igd" style="cursor:pointer">
      <rect x="415" y="532" width="625" height="46" rx="5" fill="#0E6655" opacity=".08" stroke="#0E6655" stroke-width="1" stroke-opacity=".38" stroke-dasharray="4 3"/>
      <text x="423" y="549" font-size="11" font-weight="500" fill="#0E6655" font-family="var(--font-sans)">IMM-2 IGD: Imunisasi Darurat / Situasi Wabah</text>
      <text x="423" y="564" font-size="10" fill="#0B5345" font-family="var(--font-sans)">PIC: Dokter/Perawat IGD | saat kondisi KLB / outbreak — dikoordinasikan dengan Dinkes</text>
      <rect x="895" y="538" width="86" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="938" y="549" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="467" y1="578" x2="912" y2="578" stroke="#0E6655" stroke-width="1.1" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".6"/>
      <text x="690" y="574" text-anchor="middle" font-size="9" fill="#0E6655" font-family="var(--font-sans)">POST /Immunization (status: completed)</text>
    </g>

    <!-- Note IGD -->
    <rect x="60" y="592" width="970" height="58" rx="5" fill="none" stroke="#e2e8f0" stroke-width=".8"/>
    <text x="70" y="608" font-size="9" font-weight="500" fill="#922B21" font-family="var(--font-sans)">⚠️ IGD Khusus: PEP (tetanus/rabies/HBIg) WAJIB dicatat jika diberikan — ini merupakan tindakan medis darurat yang harus terdokumentasi.</text>
    <text x="70" y="622" font-size="9" fill="#475569" font-family="var(--font-sans)">Urutan IGD: Encounter(EMER) → Triase + anamnesis → Dokter order PEP → Perawat berikan → POST /Immunization → Encounter finished</text>
    <text x="70" y="636" font-size="9" fill="#C0392B" font-family="var(--font-sans)">Vaksin yang sering di IGD: Tetanus Toksoid (TT/Td), Anti Tetanus Serum (ATS), Vaksin Rabies, Hepatitis B Immunoglobulin (HBIg)</text>

    <!-- ============================================================ -->
    <!-- MODUL RANAP -->
    <!-- ============================================================ -->
    <rect x="8" y="668" width="1044" height="22" rx="4" fill="#6C3483" opacity=".14"/>
    <text x="14" y="683" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">MODUL RAWAT INAP (RANAP) — Posisi Immunization</text>

    <!-- Actor boxes Ranap -->
    <rect x="52"  y="696" width="90" height="34" rx="6" fill="#1F618D"/>
    <text x="97"  y="711" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Admisi</text>
    <text x="97"  y="723" text-anchor="middle" font-size="8" fill="#AED6F1" font-family="var(--font-sans)">(Pendaftaran)</text>

    <rect x="172" y="696" width="90" height="34" rx="6" fill="#1E8449"/>
    <text x="217" y="711" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Perawat</text>
    <text x="217" y="723" text-anchor="middle" font-size="8" fill="#A9DFBF" font-family="var(--font-sans)">(Bangsal)</text>

    <rect x="292" y="696" width="90" height="34" rx="6" fill="#6C3483"/>
    <text x="337" y="711" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">DPJP</text>
    <text x="337" y="723" text-anchor="middle" font-size="8" fill="#D7BDE2" font-family="var(--font-sans)">(Dokter)</text>

    <rect x="412" y="696" width="110" height="34" rx="6" fill="#0E6655"/>
    <text x="467" y="711" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Vaksinator</text>
    <text x="467" y="723" text-anchor="middle" font-size="8" fill="#A2D9CE" font-family="var(--font-sans)">(Tim Imunisasi)</text>

    <rect x="540" y="696" width="110" height="34" rx="6" fill="#7B241C"/>
    <text x="595" y="711" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Spesialis</text>
    <text x="595" y="723" text-anchor="middle" font-size="8" fill="#F1948A" font-family="var(--font-sans)">(Konsultan)</text>

    <rect x="800" y="696" width="240" height="34" rx="6" fill="#C0392B"/>
    <text x="920" y="715" text-anchor="middle" font-size="10" font-weight="500" fill="#fff" font-family="var(--font-sans)">SATUSEHAT Platform</text>

    <!-- Lifelines Ranap -->
    <line x1="97"  y1="730" x2="97"  y2="1530" stroke="#1F618D" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="217" y1="730" x2="217" y2="1530" stroke="#1E8449" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="337" y1="730" x2="337" y2="1530" stroke="#6C3483" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="467" y1="730" x2="467" y2="1530" stroke="#0E6655" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="595" y1="730" x2="595" y2="1530" stroke="#7B241C" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="920" y1="730" x2="920" y2="1530" stroke="#C0392B" stroke-width="1" stroke-dasharray="3 4" opacity=".25"/>

    <!-- Encounter Ranap konteks -->
    <rect x="60" y="738" width="970" height="32" rx="4" fill="#4A90D9" opacity=".08" stroke="#4A90D9" stroke-width="1" stroke-opacity=".4"/>
    <text x="68" y="754" font-size="10" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">Encounter (IMP, in-progress) — anchor semua resource ranap</text>
    <line x1="97" y1="770" x2="912" y2="770" stroke="#4A90D9" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".5"/>

    <!-- Fase asesmen awal label -->
    <rect x="60" y="778" width="970" height="16" rx="3" fill="#1E8449" opacity=".08"/>
    <text x="68" y="789" font-size="9" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">↓ Asesmen Awal Masuk (review riwayat imunisasi dalam 24 jam pertama)</text>

    <!-- IMM Ranap 1: Review Riwayat Imunisasi -->
    <g class="rn" data-id="imm_review_ranap" data-mod="ranap" style="cursor:pointer">
      <rect x="175" y="802" width="845" height="46" rx="5" fill="#1E8449" opacity=".1" stroke="#1E8449" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="183" y="819" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">IMM-1 Ranap: Review Riwayat Imunisasi (Asesmen Masuk)</text>
