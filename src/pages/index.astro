---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rawat Jalan (Rajal)" pageTitle="Rawat Jalan (Rajal)" icon="fa-hospital-user">
  <div class="wrap">
  <div class="header">
    <h2><i class="fa-solid fa-notes-medical" style="color: #C0392B;"></i> Alur SATUSEHAT Rajal — Lengkap dengan Lab, Farmasi & Radiologi</h2>
    <div class="sub">Klik resource untuk detail implementasi · Pilih tab untuk fokus per jalur</div>
  </div>

  <div class="tab-bar">
    <button class="tab on" onclick="showPhase('all',this)"><i class="fa-solid fa-border-all"></i> Semua Jalur</button>
    <button class="tab" onclick="showPhase('pendaftaran',this)"><i class="fa-solid fa-hospital-user"></i> Pendaftaran</button>
    <button class="tab" onclick="showPhase('perawat',this)"><i class="fa-solid fa-user-nurse"></i> Keperawatan</button>
    <button class="tab" onclick="showPhase('dokter',this)"><i class="fa-solid fa-user-doctor"></i> Dokter</button>
    <button class="tab" onclick="showPhase('farmasi',this)"><i class="fa-solid fa-pills"></i> Farmasi</button>
    <button class="tab" onclick="showPhase('lab',this)"><i class="fa-solid fa-flask-vial"></i> Laboratorium</button>
    <button class="tab" onclick="showPhase('radiologi',this)"><i class="fa-solid fa-x-ray"></i> Radiologi</button>
    <button class="tab" onclick="showPhase('selesai',this)"><i class="fa-solid fa-person-walking-arrow-right"></i> Selesai</button>
  </div>

  <div class="legend">
    <div class="leg"><div class="leg-dot pulse" style="background:#1F618D"></div>Pendaftaran</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#1E8449"></div>Keperawatan</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#6C3483"></div>Dokter</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#117A65"></div>Farmasi</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#1A5276"></div>Laboratorium</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#7B241C"></div>Radiologi</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#C0392B"></div>Wajib</div>
    <div class="leg"><div class="leg-dot" style="background:#888"></div>Opsional</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#E67E22"></div>DICOM/NIDR</div>
  </div>

  <div class="scroll">
  <svg id="svg" width="1080" viewBox="0 0 1080 1680" role="img">
    <title>Alur integrasi SATUSEHAT rawat jalan lengkap dengan farmasi, laboratorium, dan radiologi</title>
    <desc>Sequence diagram FHIR resource SATUSEHAT untuk rawat jalan dengan 7 aktor: Pasien, Pendaftaran, Perawat, Dokter, Farmasi, Laboratorium, Radiologi, dan SATUSEHAT Platform</desc>
    <defs>
      <marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
        <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </marker>
    </defs>

    <!-- ===== ACTOR HEADERS ===== -->
    <!-- x centers: Pasien=55, Pendaftaran=160, Perawat=265, Dokter=370, Farmasi=490, Lab=605, Radiologi=720, SATUSEHAT=940 -->
    <g>
      <rect x="10" y="8" width="88" height="36" rx="7" fill="#2C3E50"/>
      <text x="54" y="30" text-anchor="middle" font-size="11" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Pasien</text>

      <rect x="114" y="8" width="94" height="36" rx="7" fill="#1F618D"/>
      <text x="161" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Pendaftaran</text>
      <text x="161" y="38" text-anchor="middle" font-size="9" fill="#AED6F1" font-family="var(--font-sans)">(Loket/RME)</text>

      <rect x="218" y="8" width="94" height="36" rx="7" fill="#1E8449"/>
      <text x="265" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Perawat</text>
      <text x="265" y="38" text-anchor="middle" font-size="9" fill="#A9DFBF" font-family="var(--font-sans)">(Poli)</text>

      <rect x="322" y="8" width="94" height="36" rx="7" fill="#6C3483"/>
      <text x="369" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Dokter</text>
      <text x="369" y="38" text-anchor="middle" font-size="9" fill="#D7BDE2" font-family="var(--font-sans)">(Poli)</text>

      <rect x="440" y="8" width="94" height="36" rx="7" fill="#117A65"/>
      <text x="487" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Farmasi</text>
      <text x="487" y="38" text-anchor="middle" font-size="9" fill="#A2D9CE" font-family="var(--font-sans)">(Apotek)</text>

      <rect x="558" y="8" width="94" height="36" rx="7" fill="#1A5276"/>
      <text x="605" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Laboratorium</text>
      <text x="605" y="38" text-anchor="middle" font-size="9" fill="#AED6F1" font-family="var(--font-sans)">(Lab Klinik)</text>

      <rect x="672" y="8" width="94" height="36" rx="7" fill="#7B241C"/>
      <text x="719" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Radiologi</text>
      <text x="719" y="38" text-anchor="middle" font-size="9" fill="#F1948A" font-family="var(--font-sans)">(RIS/PACS)</text>

      <rect x="848" y="8" width="218" height="36" rx="7" fill="#C0392B"/>
      <text x="957" y="22" text-anchor="middle" font-size="11" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">SATUSEHAT Platform</text>
      <text x="957" y="36" text-anchor="middle" font-size="9" fill="#F1948A" font-family="var(--font-sans)">+ NIDR (National Imaging Data Repository)</text>
    </g>

    <!-- Lifelines -->
    <line x1="54"  y1="44" x2="54"  y2="1672" stroke="#2C3E50" stroke-width=".8" stroke-dasharray="3 4" opacity=".25"/>
    <line x1="161" y1="44" x2="161" y2="1672" stroke="#1F618D" stroke-width=".8" stroke-dasharray="3 4" opacity=".25"/>
    <line x1="265" y1="44" x2="265" y2="1672" stroke="#1E8449" stroke-width=".8" stroke-dasharray="3 4" opacity=".25"/>
    <line x1="369" y1="44" x2="369" y2="1672" stroke="#6C3483" stroke-width=".8" stroke-dasharray="3 4" opacity=".25"/>
    <line x1="487" y1="44" x2="487" y2="1672" stroke="#117A65" stroke-width=".8" stroke-dasharray="3 4" opacity=".25"/>
    <line x1="605" y1="44" x2="605" y2="1672" stroke="#1A5276" stroke-width=".8" stroke-dasharray="3 4" opacity=".25"/>
    <line x1="719" y1="44" x2="719" y2="1672" stroke="#7B241C" stroke-width=".8" stroke-dasharray="3 4" opacity=".25"/>
    <line x1="957" y1="44" x2="957" y2="1672" stroke="#C0392B" stroke-width="1.2" stroke-dasharray="3 4" opacity=".3"/>

    <!-- ===== FASE 1: PENDAFTARAN ===== -->
    <rect x="8" y="56" width="1064" height="20" rx="3" fill="#1F618D" opacity=".12"/>
    <text x="14" y="70" font-size="10" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">FASE 1 — Pendaftaran &amp; Kunjungan</text>

    <text x="57" y="98" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Datang &amp; mendaftar</text>
    <line x1="54" y1="102" x2="154" y2="102" stroke="#1F618D" stroke-width="1.5" marker-end="url(#ar)"/>

    <!-- Encounter Arrived -->
    <g class="rn" data-id="enc1" style="cursor:pointer" data-phase="pendaftaran">
      <rect x="118" y="110" width="950" height="44" rx="5" fill="#4A90D9" opacity=".12" stroke="#4A90D9" stroke-width="1.2" stroke-opacity=".55"/>
      <text x="127" y="127" font-size="11" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">1. Encounter</text>
      <text x="127" y="142" font-size="10" fill="#2874A6" font-family="var(--font-sans)">status: arrived | class: AMB | serviceType: kode poli | subject: Patient (IHS Number)</text>
      <rect x="924" y="116" width="50" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="949" y="127" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="161" y1="154" x2="948" y2="154" stroke="#4A90D9" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="540" y="150" text-anchor="middle" font-size="9" fill="#4A90D9" font-family="var(--font-sans)">POST /Encounter → simpan encounter-id</text>
    </g>

    <!-- ===== FASE 2: KEPERAWATAN ===== -->
    <rect x="8" y="168" width="1064" height="20" rx="3" fill="#1E8449" opacity=".12"/>
    <text x="14" y="182" font-size="10" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">FASE 2 — Asesmen Awal Perawat</text>

    <text x="164" y="205" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Asesmen awal</text>
    <line x1="161" y1="209" x2="258" y2="209" stroke="#1E8449" stroke-width="1.5" marker-end="url(#ar)"/>

    <g class="rn" data-id="obs_vital" style="cursor:pointer" data-phase="perawat">
      <rect x="222" y="216" width="846" height="44" rx="5" fill="#27AE60" opacity=".1" stroke="#27AE60" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="231" y="233" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">2. Observation — Tanda Vital</text>
      <text x="231" y="248" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Tensi, suhu, nadi, BB, TB, saturasi O2 | 1 Observation per parameter | kode LOINC</text>
      <rect x="924" y="222" width="50" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="949" y="233" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="265" y1="260" x2="948" y2="260" stroke="#27AE60" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="600" y="256" text-anchor="middle" font-size="9" fill="#27AE60" font-family="var(--font-sans)">POST /Observation (multiple)</text>
    </g>

    <g class="rn" data-id="allergy" style="cursor:pointer" data-phase="perawat">
      <rect x="222" y="272" width="846" height="44" rx="5" fill="#27AE60" opacity=".1" stroke="#27AE60" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="231" y="289" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">3. AllergyIntolerance — Riwayat Alergi</text>
      <text x="231" y="304" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Alergi obat/makanan/lingkungan | jika tidak ada: kode NKA (No Known Allergy)</text>
      <rect x="924" y="278" width="50" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="949" y="289" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="265" y1="316" x2="948" y2="316" stroke="#27AE60" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="600" y="312" text-anchor="middle" font-size="9" fill="#27AE60" font-family="var(--font-sans)">POST /AllergyIntolerance</text>
    </g>

    <g class="rn" data-id="fmhist" style="cursor:pointer" data-phase="perawat">
      <rect x="222" y="328" width="846" height="40" rx="5" fill="#27AE60" opacity=".06" stroke="#27AE60" stroke-width="1" stroke-opacity=".35" stroke-dasharray="4 3"/>
      <text x="231" y="344" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">4. FamilyMemberHistory — Riwayat Keluarga</text>
      <text x="231" y="358" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Penyakit herediter keluarga (DM, hipertensi, kanker) | opsional</text>
      <rect x="906" y="334" width="66" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="939" y="345" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="265" y1="368" x2="948" y2="368" stroke="#27AE60" stroke-width="1" marker-end="url(#ar)" stroke-dasharray="3 4" stroke-opacity=".5"/>
    </g>

    <g class="rn" data-id="medstat" style="cursor:pointer" data-phase="perawat">
      <rect x="222" y="376" width="846" height="40" rx="5" fill="#27AE60" opacity=".06" stroke="#27AE60" stroke-width="1" stroke-opacity=".35" stroke-dasharray="4 3"/>
      <text x="231" y="392" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">5. MedicationStatement — Obat Sedang Dikonsumsi</text>
      <text x="231" y="406" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Obat rutin / swamedikasi pasien sebelum kunjungan | opsional</text>
      <rect x="906" y="382" width="66" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="939" y="393" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="265" y1="416" x2="948" y2="416" stroke="#27AE60" stroke-width="1" marker-end="url(#ar)" stroke-dasharray="3 4" stroke-opacity=".5"/>
    </g>

    <!-- ===== FASE 3: DOKTER ===== -->
    <rect x="8" y="428" width="1064" height="20" rx="3" fill="#6C3483" opacity=".12"/>
    <text x="14" y="442" font-size="10" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">FASE 3 — Pemeriksaan Dokter</text>

    <text x="372" y="464" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Pemeriksaan</text>
    <line x1="369" y1="468" x2="369" y2="468" stroke="#6C3483" stroke-width="1.5"/>

    <g class="rn" data-id="clinical" style="cursor:pointer" data-phase="dokter">
      <rect x="326" y="472" width="742" height="40" rx="5" fill="#9B6BBE" opacity=".06" stroke="#9B6BBE" stroke-width="1" stroke-opacity=".35" stroke-dasharray="4 3"/>
      <text x="335" y="488" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">6. ClinicalImpression — Catatan SOAP / Anamnesis</text>
      <text x="335" y="502" font-size="10" fill="#7D3C98" font-family="var(--font-sans)">Riwayat penyakit sekarang, SOAP note, ringkasan klinis dokter | opsional</text>
      <rect x="906" y="478" width="66" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="939" y="489" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="369" y1="512" x2="948" y2="512" stroke="#9B6BBE" stroke-width="1" marker-end="url(#ar)" stroke-dasharray="3 4" stroke-opacity=".5"/>
    </g>

    <g class="rn" data-id="condition" style="cursor:pointer" data-phase="dokter">
      <rect x="326" y="522" width="742" height="44" rx="5" fill="#9B6BBE" opacity=".12" stroke="#9B6BBE" stroke-width="1.2" stroke-opacity=".55"/>
      <text x="335" y="539" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">7. Condition — Diagnosa Utama &amp; Sekunder</text>
      <text x="335" y="554" font-size="10" fill="#7D3C98" font-family="var(--font-sans)">Kode ICD-10 wajib | clinicalStatus: active | dikirim SEBELUM Procedure</text>
      <rect x="924" y="528" width="50" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="949" y="539" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="369" y1="566" x2="948" y2="566" stroke="#9B6BBE" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="660" y="562" text-anchor="middle" font-size="9" fill="#9B6BBE" font-family="var(--font-sans)">POST /Condition → simpan condition-id</text>
    </g>

    <g class="rn" data-id="procedure" style="cursor:pointer" data-phase="dokter">
      <rect x="326" y="576" width="742" height="44" rx="5" fill="#9B6BBE" opacity=".12" stroke="#9B6BBE" stroke-width="1.2" stroke-opacity=".55"/>
      <text x="335" y="593" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">8. Procedure — Tindakan Medis di Poli</text>
      <text x="335" y="608" font-size="10" fill="#7D3C98" font-family="var(--font-sans)">Kode ICD-9-CM | reasonReference → Condition ID | performer: Dokter</text>
      <rect x="924" y="582" width="50" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="949" y="593" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="369" y1="620" x2="948" y2="620" stroke="#9B6BBE" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="660" y="616" text-anchor="middle" font-size="9" fill="#9B6BBE" font-family="var(--font-sans)">POST /Procedure (setelah Condition)</text>
    </g>

    <!-- ===== FASE 4A: FARMASI ===== -->
    <rect x="8" y="638" width="1064" height="20" rx="3" fill="#117A65" opacity=".14"/>
    <text x="14" y="652" font-size="10" font-weight="500" fill="#117A65" font-family="var(--font-sans)">FASE 4A — Order &amp; Penyerahan Obat (Farmasi)</text>

    <text x="372" y="675" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Order resep</text>
    <line x1="369" y1="679" x2="480" y2="679" stroke="#117A65" stroke-width="1.5" marker-end="url(#ar)"/>

    <g class="rn" data-id="medrq" style="cursor:pointer" data-phase="farmasi">
      <rect x="444" y="686" width="624" height="44" rx="5" fill="#1ABC9C" opacity=".1" stroke="#1ABC9C" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="453" y="703" font-size="11" font-weight="500" fill="#117A65" font-family="var(--font-sans)">9. MedicationRequest — E-Resep (Medication contained)</text>
      <text x="453" y="718" font-size="10" fill="#0E6655" font-family="var(--font-sans)">Medication di dalam contained | kode obat Kemenkes | dosageInstruction | dispenseRequest</text>
      <rect x="924" y="692" width="50" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="949" y="703" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="487" y1="730" x2="948" y2="730" stroke="#1ABC9C" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="715" y="726" text-anchor="middle" font-size="9" fill="#1ABC9C" font-family="var(--font-sans)">POST /MedicationRequest → simpan medrq-id</text>
    </g>

    <g class="rn" data-id="meddisp" style="cursor:pointer" data-phase="farmasi">
      <rect x="444" y="742" width="624" height="44" rx="5" fill="#1ABC9C" opacity=".1" stroke="#1ABC9C" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="453" y="759" font-size="11" font-weight="500" fill="#117A65" font-family="var(--font-sans)">10. MedicationDispense — Obat Fisik Diserahkan</text>
      <text x="453" y="774" font-size="10" fill="#0E6655" font-family="var(--font-sans)">authorizingPrescription → MedicationRequest ID | whenHandedOver | receiver: Patient</text>
      <rect x="924" y="748" width="50" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="949" y="759" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="487" y1="786" x2="948" y2="786" stroke="#1ABC9C" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="715" y="782" text-anchor="middle" font-size="9" fill="#1ABC9C" font-family="var(--font-sans)">POST /MedicationDispense</text>
    </g>
    <!-- Serahkan ke pasien -->
    <line x1="487" y1="798" x2="62" y2="798" stroke="#1ABC9C" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="3 3" stroke-opacity=".5"/>
    <text x="270" y="810" text-anchor="middle" font-size="9" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Serahkan obat ke pasien</text>

    <!-- ===== FASE 4B: LABORATORIUM ===== -->
    <rect x="8" y="822" width="1064" height="20" rx="3" fill="#1A5276" opacity=".14"/>
    <text x="14" y="836" font-size="10" font-weight="500" fill="#1A5276" font-family="var(--font-sans)">FASE 4B — Pemeriksaan Laboratorium (jika ada order lab)</text>

    <text x="372" y="860" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Order lab</text>
    <line x1="369" y1="864" x2="596" y2="864" stroke="#1A5276" stroke-width="1.5" marker-end="url(#ar)"/>

    <g class="rn" data-id="svcreq_lab" style="cursor:pointer" data-phase="lab">
      <rect x="562" y="870" width="506" height="44" rx="5" fill="#2E86C1" opacity=".1" stroke="#2E86C1" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="571" y="887" font-size="11" font-weight="500" fill="#1A5276" font-family="var(--font-sans)">11. ServiceRequest — Order Pemeriksaan Lab</text>
      <text x="571" y="902" font-size="10" fill="#154360" font-family="var(--font-sans)">category: laboratory | kode LOINC panel | reasonReference → Condition ID</text>
