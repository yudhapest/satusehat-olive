---
import Layout from '../layouts/Layout.astro';
import orgsData from '../data/locations.json';

interface LocItem { name: string; kd: string; ss: string; }
interface OrgGroup { idorg: number; name: string; ss: string; cat: string; locations: LocItem[]; }

const orgs = orgsData as OrgGroup[];

const CAT: Record<string, { label: string; color: string; icon: string }> = {
  penunjang: { label: 'Bidang Penunjang', color: '#1E8449', icon: 'fa-flask-vial' },
  pelayanan: { label: 'Bidang Pelayanan', color: '#6C3483', icon: 'fa-hospital-user' },
  keperawatan: { label: 'Keperawatan', color: '#7B241C', icon: 'fa-bed-pulse' },
};

const TAB_ORDER = ['penunjang', 'pelayanan', 'keperawatan'];
const groups = TAB_ORDER.map((cat) => ({
  cat,
  ...CAT[cat],
  orgs: orgs
    .filter((o) => o.cat === cat)
    .sort((a, b) => a.idorg - b.idorg),
}));

const totalLoc = orgs.reduce((n, o) => n + o.locations.length, 0);
const locByCat = (c: string) =>
  orgs.filter((o) => o.cat === c).reduce((n, o) => n + o.locations.length, 0);
---

<Layout title="Location" pageTitle="Location (Bagian)" icon="fa-location-dot">
  <div class="wrap">
    <div class="tab-bar">
      <button class="tab on" onclick="showLocGroup('all', this)"><i class="fa-solid fa-border-all"></i> Semua</button>
      <button class="tab" onclick="showLocGroup('penunjang', this)"><i class="fa-solid fa-flask-vial"></i> Bidang Penunjang</button>
      <button class="tab" onclick="showLocGroup('pelayanan', this)"><i class="fa-solid fa-hospital-user"></i> Bidang Pelayanan</button>
      <button class="tab" onclick="showLocGroup('keperawatan', this)"><i class="fa-solid fa-bed-pulse"></i> Keperawatan</button>
    </div>

    <div class="resource-summary-grid">
      <div class="summary-card"><strong>{totalLoc}</strong><span>Total Location terkirim</span></div>
      <div class="summary-card"><strong>{locByCat('penunjang')}</strong><span>Location di Bidang Penunjang</span></div>
      <div class="summary-card"><strong>{locByCat('pelayanan')}</strong><span>Location di Bidang Pelayanan</span></div>
      <div class="summary-card"><strong>{locByCat('keperawatan')}</strong><span>Location di Keperawatan</span></div>
    </div>

    <div class="scroll">
      <div class="loc-tree">
        <div class="loc-root">
          <i class="fa-solid fa-hospital"></i>
          <div>
            <strong>RSU Sebening Kasih</strong>
            <small>Organization induk · ID: 100027830</small>
          </div>
        </div>

        <div class="loc-cats">
          {
            groups.map((g) => (
              <div class="loc-cat" data-group={g.cat} style={`--c:${g.color}`}>
                <div class="loc-cat-head">
                  <i class={`fa-solid ${g.icon}`} /> {g.label}
                </div>
                <div class="loc-orgs">
                  {g.orgs.map((org) => (
                    <div class="loc-org">
                      <div class="loc-org-head">
                        <span class="loc-org-name">{org.name}</span>
                        <span class="loc-org-meta">ID: {org.idorg} · {org.locations.length} lokasi</span>
                        <span class="loc-org-ss">SS: {org.ss}</span>
                      </div>
                      <div class="loc-cards">
                        {org.locations.map((loc) => (
                          <button
                            class="loc-card"
                            type="button"
                            data-name={loc.name}
                            data-kd={loc.kd}
                            data-ss={loc.ss}
                            data-org={org.name}
                            data-idorg={String(org.idorg)}
                            data-orgss={org.ss}
                            data-color={g.color}
                            data-catlabel={g.label}
                          >
                            <span class="loc-card-name">{loc.name}</span>
                            <span class="loc-card-sub">kd: {loc.kd}</span>
                            <span class="loc-card-sub">SS: {loc.ss}</span>
                          </button>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="info" id="info">
      <span class="hint"><i class="fa-solid fa-hand-pointer"></i> Klik salah satu Location untuk melihat kode, idsatusehat, dan Organization induknya.</span>
    </div>
  </div>
</Layout>

<style>
  .loc-tree {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 100%;
    width: max-content;
  }

  /* Root */
  .loc-root {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 22px;
    border-radius: 14px;
    background: linear-gradient(180deg, #C0392B, #97271b);
    color: #fff;
    box-shadow: 0 8px 22px rgba(192, 57, 43, 0.28);
    position: relative;
  }
  .loc-root i { font-size: 20px; opacity: 0.95; }
  .loc-root strong { display: block; font-size: 15px; font-weight: 800; }
  .loc-root small { font-size: 11px; opacity: 0.85; }
  .loc-root::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -22px;
    width: 0;
    height: 22px;
    border-left: 1.5px dashed var(--color-border-tertiary);
  }

  /* Category columns */
  .loc-cats {
    display: flex;
    align-items: flex-start;
    gap: 28px;
    padding-top: 22px;
    border-top: 1.5px dashed var(--color-border-tertiary);
    margin-top: 22px;
  }
  .loc-cat { display: flex; flex-direction: column; align-items: center; gap: 14px; position: relative; }
  .loc-cat::before {
    content: '';
    position: absolute;
    top: -22px;
    left: 50%;
    width: 0;
    height: 22px;
    border-left: 1.5px dashed var(--color-border-tertiary);
  }
  .loc-cat-head {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 10px;
    background: var(--c);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 6px 16px color-mix(in srgb, var(--c) 30%, transparent);
  }

  .loc-orgs { display: flex; align-items: flex-start; gap: 16px; }
  .loc-org { display: flex; flex-direction: column; gap: 10px; width: 196px; }

  .loc-org-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    padding: 9px 12px;
    border-radius: 9px;
    background: linear-gradient(180deg, var(--c), color-mix(in srgb, var(--c) 78%, #000));
    color: #fff;
    text-align: center;
    box-shadow: 0 5px 14px color-mix(in srgb, var(--c) 28%, transparent);
  }
  .loc-org-name { font-size: 12.5px; font-weight: 800; line-height: 1.2; }
  .loc-org-meta { font-size: 10px; opacity: 0.92; font-weight: 600; }
  .loc-org-ss { font-size: 9.5px; opacity: 0.8; }

  /* Cards stacked directly (same look as Organization chart) */
  .loc-cards { display: flex; flex-direction: column; gap: 8px; }
  .loc-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    width: 100%;
    padding: 8px 10px 8px 14px;
    background: var(--color-bg-glass-darker);
    border: 1px solid var(--color-border);
    border-radius: 9px;
    box-shadow: var(--shadow-soft);
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    font-family: var(--font-sans);
    text-align: center;
  }
  .loc-card::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 9px;
    bottom: 9px;
    width: 3px;
    border-radius: 2px;
    background: var(--c);
  }
  .loc-card:hover,
  .loc-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
    border-color: color-mix(in srgb, var(--c) 40%, var(--color-border));
    outline: none;
  }
  .loc-card-name {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--c);
    line-height: 1.2;
  }
  .loc-card-sub {
    font-size: 9.5px;
    font-weight: 600;
    color: var(--color-text-tertiary);
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .loc-cats { gap: 18px; }
    .loc-org { width: 168px; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    (window as any).showLocGroup = function (group: string, btn: HTMLElement) {
      document.querySelectorAll('.tab').forEach((t) => t.classList.remove('on'));
      btn.classList.add('on');
      document.querySelectorAll<HTMLElement>('.loc-cat').forEach((cat) => {
        const show = group === 'all' || cat.dataset.group === group;
        cat.style.display = show ? '' : 'none';
      });
    };

    const infoPanel = document.getElementById('info');
    document.querySelectorAll<HTMLElement>('.loc-card').forEach((card) => {
      card.addEventListener('click', () => {
        const d = card.dataset;
        const color = d.color || '#1E8449';
        if (!infoPanel) return;
        infoPanel.innerHTML = `
          <div class="rc" style="animation: rcFadeIn 0.35s ease both;">
            <div class="rc__head">
              <div class="rc__icon" style="background: ${color}; box-shadow: 0 6px 16px color-mix(in srgb, ${color} 35%, transparent);"><i class="fa-solid fa-location-dot"></i></div>
              <div class="rc__headtext">
                <h3 class="rc__title">${d.name ?? ''}</h3>
                <div class="rc__status"><div class="rc__status-dot" style="background:${color}"></div>Location · ${d.catlabel ?? ''}</div>
              </div>
            </div>
            <div class="rc__section">
              <div class="rc__section-ic"><i class="fa-solid fa-circle-info"></i></div>
              <h4>Detail Location</h4>
            </div>
            <div class="rc__fields">
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-barcode"></i> Kode Bagian</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val">${d.kd ?? ''}</div>
              </div>
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-fingerprint"></i> Loc idsatusehat</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val">${d.ss ?? ''}</div>
              </div>
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-hospital"></i> Organization</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val">${d.org ?? ''} (idorg: ${d.idorg ?? ''})</div>
              </div>
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-fingerprint"></i> Org idsatusehat</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val">${d.orgss ?? ''}</div>
              </div>
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-link"></i> Relasi FHIR</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val rc-field__val--solo">Location.managingOrganization → Organization (${d.org ?? ''})</div>
              </div>
            </div>
          </div>
        `;
        infoPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });
  });
</script>
