<Layout title="Struktur Organisasi" pageTitle="Struktur Organisasi" icon="fa-sitemap">
  <div class="wrap">
    <div class="header">
      <h2><i class="fa-solid fa-sitemap" style="color: #C0392B;"></i> Struktur Organisasi SATUSEHAT — RSU Sebening Kasih</h2>
      <div class="sub">53 unit organisasi · Data dari tabel <code>_ref_organisasi</code> SIMRS · Klik node untuk detail · Klik tab untuk filter per divisi</div>
    </div>

    <div class="tab-bar">
      <button class="tab on" id="tab-semua" onclick="showDiv('semua', this)"><i class="fa-solid fa-border-all"></i> Semua</button>
      <button class="tab" onclick="showDiv('direksi', this)"><i class="fa-solid fa-user-tie"></i> Komite & Tim</button>
      <button class="tab" onclick="showDiv('penunjang', this)"><i class="fa-solid fa-gear"></i> Bid. Penunjang</button>
      <button class="tab" onclick="showDiv('pelayanan', this)"><i class="fa-solid fa-hospital-user"></i> Bid. Pelayanan</button>
      <button class="tab" onclick="showDiv('administrasi', this)"><i class="fa-solid fa-file-invoice"></i> Administrasi</button>
    </div>

    <div class="legend">
      <div class="leg"><div class="leg-dot pulse" style="background:#C0392B"></div>Direktur</div>
      <div class="leg"><div class="leg-dot pulse" style="background:#2C3E50"></div>Komite & Tim</div>
      <div class="leg"><div class="leg-dot pulse" style="background:#1F618D"></div>Bid. Penunjang</div>
      <div class="leg"><div class="leg-dot pulse" style="background:#1E8449"></div>Penunjang Medis</div>
      <div class="leg"><div class="leg-dot pulse" style="background:#117A65"></div>Penunjang Non Medis</div>
      <div class="leg"><div class="leg-dot pulse" style="background:#6C3483"></div>Pelayanan Medis</div>
      <div class="leg"><div class="leg-dot pulse" style="background:#7B241C"></div>Keperawatan</div>
      <div class="leg"><div class="leg-dot pulse" style="background:#E67E22"></div>Administrasi</div>
    </div>

    <div class="scroll" id="org-scroll">
      <svg
        id="svg-org"
        viewBox={`0 0 ${totalW} ${totalH}`}
        role="img"
        style={`min-width:${totalW}px;width:100%;height:auto;`}
      >
        <title>Struktur Organisasi RSU Sebening Kasih</title>

        <defs>
          <filter id="cardShadow" x="-30%" y="-30%" width="160%" height="160%">
            <feDropShadow dx="0" dy="3" stdDeviation="4" flood-color="#1f2687" flood-opacity="0.10" />
          </filter>
          <filter id="solidShadow" x="-40%" y="-40%" width="180%" height="180%">
            <feDropShadow dx="0" dy="5" stdDeviation="7" flood-color="#1f2687" flood-opacity="0.22" />
          </filter>
          {uniqColors.map((hex) => (
            <linearGradient id={gradId(hex)} x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color={hex} />
              <stop offset="100%" stop-color={darken(hex, 0.22)} />
            </linearGradient>
          ))}
        </defs>

        {/* ===== Kontainer cluster Komite & Tim ===== */}
        <rect
          x={PAD - 10}
          y={depth1Y - 6}
          width={komiteBlockW + 20}
          height={komiteBlockH + 12}
          rx="8"
          fill={COLORS.komite}
          fill-opacity="0.04"
          stroke={COLORS.komite}
          stroke-width="1"
          stroke-opacity="0.25"
          stroke-dasharray="4 3"
        />

        {/* ===== Konektor ===== */}
        {connectors.map((c) => (
          <path
            class="org-line"
            data-div={c.div}
            d={c.d}
            fill="none"
            stroke={c.color}
            stroke-width="1.75"
            stroke-opacity="0.45"
            stroke-linecap="round"
            stroke-dasharray="1 7"
          />
        ))}

        {/* ===== Header cluster Komite & Tim ===== */}
        <g class="org-node" data-div="direksi" data-id="komite-box">
          <rect
            class="org-card"
            x={PAD}
            y={depth1Y}
            width={komiteBlockW}
            height={KOMITE_HEADER_H}
            rx="6"
            fill={`url(#${gradId(COLORS.komite)})`}
            filter="url(#solidShadow)"
          />
          <text
            x={komiteHeaderCx}
            y={depth1Y + 17}
            text-anchor="middle"
            font-size="12"
            font-weight="600"
            fill="#ffffff"
            font-family="var(--font-sans)"
          >
            Komite &amp; Tim Fungsional
          </text>
        </g>

        {/* ===== Node ===== */}
        {defs.map((d) => {
          const p = pos.get(d.id)!;
          const color = COLORS[d.cat];
          const cx = p.x + W / 2;
          const solid = SOLID.has(d.id);
          const meta = `ID: ${d.id} | Parent: ${d.parent} · SS: ${d.ss}`;
          return (
            <g
              class="org-node animated-node"
              data-div={d.div}
              data-id={`n${d.id}`}
              data-name={d.name}
              data-meta={meta}
              data-color={color}
              data-phase={DIV_LABEL[d.div] ?? d.div}
            >
              {solid ? (
                <rect
                  class="org-card"
                  x={p.x}
                  y={p.y}
                  width={W}
                  height={H}
                  rx="9"
                  fill={`url(#${gradId(color)})`}
                  filter="url(#solidShadow)"
                />
              ) : (
                <>
                  <rect
                    class="org-card"
                    x={p.x}
                    y={p.y}
                    width={W}
                    height={H}
                    rx="9"
                    fill="#ffffff"
                    fill-opacity="0.92"
                    stroke={color}
                    stroke-width="1"
                    stroke-opacity="0.18"
                    filter="url(#cardShadow)"
                  />
                  <rect x={p.x + 8} y={p.y + 13} width="4" height={H - 26} rx="2" fill={color} />
                </>
              )}
              <text
                x={cx}
                y={p.y + 21}
                text-anchor="middle"
                font-size="9"
                fill={solid ? '#ffffff' : 'var(--color-text-tertiary)'}
                fill-opacity={solid ? '0.8' : '1'}
                font-family="var(--font-sans)"
              >
                ID: {d.id} | Parent: {d.parent}
              </text>
              <text
                x={cx}
                y={p.y + 39}
                text-anchor="middle"
                font-size={nameFs(d.name)}
                font-weight={solid ? '700' : '600'}
                fill={solid ? '#ffffff' : color}
                font-family="var(--font-sans)"
              >
                {d.name}
              </text>
              <text
                x={cx}
                y={p.y + 55}
                text-anchor="middle"
                font-size="9"
                fill={solid ? '#ffffff' : 'var(--color-text-tertiary)'}
                fill-opacity={solid ? '0.75' : '1'}
                font-family="var(--font-sans)"
              >
                SS: {d.ss}
              </text>
            </g>
          );
        })}

        {/* Footer stats */}
        <rect x="8" y={totalH - 46} width={totalW - 16} height="36" rx="10" fill="#ffffff" fill-opacity="0.55" stroke="var(--color-border-secondary)" stroke-width="1" filter="url(#cardShadow)" />
        <text x="22" y={totalH - 23} font-size="10" font-weight="500" fill="var(--color-text-secondary)" font-family="var(--font-sans)">
          📊 Struktur Organisasi RSU Sebening Kasih · Total 53 unit · Direktur → Komite & Tim (12) · Bid. Penunjang · Bid. Pelayanan · Administrasi · idsatusehat disamarkan (****)
        </text>
      </svg>
    </div>

    <div class="info" id="info">
      <span class="hint"><i class="fa-solid fa-sitemap"></i> Struktur organisasi RSU Sebening Kasih · 53 unit terdaftar di SATUSEHAT · Gunakan tab di atas untuk fokus per divisi.</span>
    </div>
  </div>
</Layout>

<style>
  @keyframes nodeSlideIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animated-node {
    animation: nodeSlideIn 0.45s ease;
  }

  @keyframes dashFlow {
    to { stroke-dashoffset: -40; }
  }
  .org-line-animated {
    animation: dashFlow 2.2s linear infinite;
  }

  .org-node {
    cursor: pointer;
    transition: transform 0.2s ease;
  }
  .org-card {
    transition: stroke-opacity 0.2s ease;
  }
  .org-node:hover {
    transform: translateY(-4px);
  }
  .org-node:hover .org-card {
    stroke-opacity: 0.5;
  }

  .org-node.dimmed {
    opacity: 0.06;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .org-line.dimmed {
    opacity: 0.04;
    transition: opacity 0.3s ease;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.org-line').forEach((line) => {
      line.classList.add('org-line-animated');
    });

    (window as any).showDiv = function (divName: string, btn: HTMLElement) {
      document.querySelectorAll('.tab').forEach((t) => t.classList.remove('on'));
      btn.classList.add('on');

      const allNodes = document.querySelectorAll<HTMLElement>('.org-node');
      const allLines = document.querySelectorAll<HTMLElement>('.org-line');

      const matches = (el: HTMLElement) => {
        const elDiv = el.dataset.div;
        return divName === 'semua' || elDiv === divName || elDiv === 'semua';
      };

      allNodes.forEach((n) => {
        if (matches(n)) {
          n.classList.remove('dimmed');
        } else {
          n.classList.add('dimmed');
        }
      });
      allLines.forEach((l) => {
        if (matches(l)) {
          l.classList.remove('dimmed');
        } else {
          l.classList.add('dimmed');
        }
      });

      if (divName !== 'semua') {
        const firstVisible = document.querySelector(`.org-node[data-div="${divName}"]`);
        if (firstVisible) firstVisible.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }
    };

    const infoPanel = document.getElementById('info');
    document.querySelectorAll<HTMLElement>('.org-node').forEach((node) => {
      node.addEventListener('click', () => {
        const name = node.dataset.name || '';
        if (!name) return;
        const meta = node.dataset.meta || '';
        const color = node.dataset.color || '#2C3E50';
        const phaseName = node.dataset.phase || '';

        if (infoPanel) {
          infoPanel.innerHTML = `
            <div class="rc" style="animation: rcFadeIn 0.35s ease both;">
              <div class="rc__head">
                <div class="rc__icon" style="background: ${color}; box-shadow: 0 6px 16px color-mix(in srgb, ${color} 35%, transparent);"><i class="fa-solid fa-users"></i></div>
                <div class="rc__headtext">
                  <h3 class="rc__title">${name}</h3>
                  <div class="rc__status"><div class="rc__status-dot" style="background:${color}"></div>${phaseName}</div>
                </div>
              </div>
              <div class="rc__section">
                <div class="rc__section-ic"><i class="fa-solid fa-circle-info"></i></div>
                <h4>Detail Organisasi</h4>
              </div>
              <div class="rc__fields">
                <div class="rc-field">
                  <div class="rc-field__name"><i class="fa-solid fa-hashtag"></i> ID & UUID</div>
                  <span class="rc-field__sep">:</span>
                  <div class="rc-field__val rc-field__val--solo">${meta}</div>
                </div>
                <div class="rc-field">
                  <div class="rc-field__name"><i class="fa-solid fa-sitemap"></i> Divisi</div>
                  <span class="rc-field__sep">:</span>
                  <div class="rc-field__val">${phaseName}</div>
                </div>
              </div>
            </div>
          `;
          infoPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    });
  });
</script>
