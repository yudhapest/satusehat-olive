---
import Layout from '../layouts/Layout.astro';
import FhirPayload from '../components/FhirPayload.astro';

interface Item { name: string; sub: string; desc: string; }
interface Cat { key: string; label: string; color: string; icon: string; items: Item[]; }

const CATS: Cat[] = [
  {
    key: 'identitas',
    label: 'Identitas Pasien',
    color: '#1F618D',
    icon: 'fa-id-card',
    items: [
      {
        name: 'NIK (KTP)',
        sub: 'Parameter pencarian utama',
        desc: 'Nomor Induk Kependudukan dipakai sebagai kunci utama mencari pasien. System: https://fhir.kemkes.go.id/id/nik.',
      },
      {
        name: 'IHS Number',
        sub: 'ID pasien nasional',
        desc: 'Hasil pencarian berupa IHS Number (Patient.id). Wajib disimpan sebagai mapping NIK ↔ IHS untuk dipakai di seluruh resource klinis.',
      },
      {
        name: 'No. Kartu Keluarga',
        sub: 'Identitas pendukung',
        desc: 'System: https://fhir.kemkes.go.id/id/kk. Dipakai pada skenario bayi baru lahir / pasien tanpa NIK.',
      },
      {
        name: 'Paspor / KITAS',
        sub: 'Untuk pasien WNA',
        desc: 'Warga negara asing diidentifikasi dengan paspor (https://fhir.kemkes.go.id/id/paspor).',
      },
    ],
  },
  {
    key: 'skenario',
    label: 'Skenario Khusus',
    color: '#6C3483',
    icon: 'fa-list-check',
    items: [
      {
        name: 'Bayi Baru Lahir',
        sub: 'Pakai NIK ibu',
        desc: 'Bayi yang belum memiliki NIK dicari/didaftarkan menggunakan NIK ibu dengan system: https://fhir.kemkes.go.id/id/nik-ibu.',
      },
      {
        name: 'Pasien Tanpa NIK',
        sub: 'Data demografis',
        desc: 'Bila NIK tidak tersedia, gunakan pencarian berdasarkan nama, tanggal lahir, dan jenis kelamin.',
      },
      {
        name: 'Pasien WNA',
        sub: 'Paspor / KITAS',
        desc: 'Pasien asing dicari memakai nomor paspor atau KITAS sebagai identifier.',
      },
    ],
  },
  {
    key: 'pakai',
    label: 'Pemakaian di Resource',
    color: '#1E8449',
    icon: 'fa-diagram-project',
    items: [
      {
        name: 'Encounter.subject',
        sub: 'Patient/{ihs}',
        desc: 'IHS Number pasien menjadi subjek setiap kunjungan (Encounter.subject.reference).',
      },
      {
        name: 'Observation / Condition',
        sub: 'subject → Patient',
        desc: 'Semua resource klinis (Observation, Condition, Procedure, dll) merujuk ke Patient/{ihs} yang sama.',
      },
      {
        name: 'Mapping Lokal',
        sub: 'NIK ↔ IHS',
        desc: 'Simpan IHS Number di SIMRS agar tidak perlu mencari ulang ke SATUSEHAT setiap transaksi.',
      },
    ],
  },
];

const totalItems = CATS.reduce((n, c) => n + c.items.length, 0);
---

<Layout title="Patient" pageTitle="Patient (Pasien)" icon="fa-user">
  <div class="wrap">
    <div class="tab-bar">
      <button class="tab on" onclick="showPatGroup('all', this)"><i class="fa-solid fa-border-all"></i> Semua</button>
      <button class="tab" onclick="showPatGroup('identitas', this)"><i class="fa-solid fa-id-card"></i> Identitas</button>
      <button class="tab" onclick="showPatGroup('skenario', this)"><i class="fa-solid fa-list-check"></i> Skenario Khusus</button>
      <button class="tab" onclick="showPatGroup('pakai', this)"><i class="fa-solid fa-diagram-project"></i> Pemakaian</button>
    </div>

    <div class="resource-summary-grid">
      <div class="summary-card"><strong>NIK</strong><span>Parameter pencarian utama</span></div>
      <div class="summary-card"><strong>IHS</strong><span>Patient ID hasil pencarian</span></div>
      <div class="summary-card"><strong>1:1</strong><span>Mapping NIK ↔ IHS</span></div>
      <div class="summary-card"><strong>{totalItems}</strong><span>Poin penting Patient</span></div>
    </div>

    <div class="scroll">
      <div class="pat-tree">
        <div class="pat-root">
          <i class="fa-solid fa-user"></i>
          <div>
            <strong>Patient (Pasien) di SATUSEHAT</strong>
            <small>Faskes tidak membuat pasien — cari by <code>NIK</code> untuk mendapatkan <code>IHS Number</code></small>
          </div>
        </div>

        <div class="pat-cats">
          {
            CATS.map((c) => (
              <div class="pat-cat" data-group={c.key} style={`--c:${c.color}`}>
                <div class="pat-cat-head">
                  <i class={`fa-solid ${c.icon}`} /> {c.label}
                </div>
                <div class="pat-cards">
                  {c.items.map((it) => (
                    <button
                      class="pat-card"
                      type="button"
                      data-name={it.name}
                      data-sub={it.sub}
                      data-desc={it.desc}
                      data-color={c.color}
                      data-catlabel={c.label}
                    >
                      <span class="pat-card-name">{it.name}</span>
                      <span class="pat-card-sub">{it.sub}</span>
                    </button>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="info" id="info">
      <span class="hint"><i class="fa-solid fa-hand-pointer"></i> Klik salah satu kartu untuk melihat detail identifier dan cara pemakaiannya pada resource SATUSEHAT.</span>
    </div>

    <FhirPayload
      title="Contoh Payload SATUSEHAT — Patient"
      examples={[
        {
          label: 'Cari Patient (NIK)',
          desc: 'Pasien dicari berdasarkan NIK untuk memperoleh <code>IHS Number</code>. Format wajib: <code>https://fhir.kemkes.go.id/id/nik|{nik}</code>. Faskes tidak membuat Patient dewasa baru.',
          code: `GET /Patient?identifier=https://fhir.kemkes.go.id/id/nik|3201xxxxxxxxxxxx
Authorization: Bearer {access_token}
Accept: application/json`,
        },
        {
          label: 'Respon (Bundle)',
          desc: 'SATUSEHAT mengembalikan <code>Bundle</code> type <code>searchset</code>. Ambil <code>entry[0].resource.id</code> sebagai IHS Number.',
          code: `{
  "resourceType": "Bundle",
  "type": "searchset",
  "total": 1,
  "entry": [
    {
      "resource": {
        "resourceType": "Patient",
        "id": "P02478375538",
        "identifier": [
          {
            "use": "official",
            "system": "https://fhir.kemkes.go.id/id/nik",
            "value": "3201xxxxxxxxxxxx"
          }
        ],
        "active": true,
        "name": [ { "use": "official", "text": "Budi Santo**" } ],
        "gender": "male",
        "birthDate": "1990-01-01"
      }
    }
  ]
}`,
        },
        {
          label: 'Bayi baru lahir (NIK ibu)',
          desc: 'Bayi belum punya NIK? Cari dengan <code>nik-ibu</code> (bukan NIK biasa). Jika belum terdaftar, gunakan <code>POST Patient</code> Create Newborn by NIK Ibu (maks. 60 hari sejak lahir).',
          code: `GET /Patient?identifier=https://fhir.kemkes.go.id/id/nik-ibu|3201xxxxxxxxxxxx
Authorization: Bearer {access_token}
Accept: application/json

// Jika belum ada → POST Create Newborn by NIK Ibu
// (lihat dokumentasi MPI SATUSEHAT)`,
        },
        {
          label: 'Referensi di Encounter',
          desc: 'IHS Number dipakai sebagai <code>subject</code> pada setiap kunjungan dan seluruh resource klinis.',
          code: `"subject": {
  "reference": "Patient/P02478375538",
  "display": "Budi Santo**"
}`,
        },
        {
          label: 'Edit (Update)?',
          desc: 'Patient dewasa = <b>data nasional</b> (Dukcapil), read-only bagi faskes. Khusus bayi: bisa <code>PATCH</code> setelah punya NIK resmi. Faskes cukup simpan mapping NIK ↔ IHS di SIMRS.',
          code: `// Dewasa: tidak ada PUT /Patient dari RS.
// Bayi sudah punya NIK → PATCH Patient (update identitas)
// Mapping lokal SIMRS:
{
  "nik": "3201xxxxxxxxxxxx",
  "patient_ihs": "P02478375538",
  "nama_lokal": "Budi Santo**"
}`,
        },
      ]}
    />
  </div>
</Layout>

<style>
  .pat-tree {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 100%;
    width: max-content;
  }

  .pat-root {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 22px;
    border-radius: 14px;
    background: linear-gradient(180deg, #C0392B, #97271b);
    color: #fff;
    box-shadow: 0 8px 22px rgba(192, 57, 43, 0.28);
    position: relative;
  }
  .pat-root i { font-size: 20px; opacity: 0.95; }
  .pat-root strong { display: block; font-size: 15px; font-weight: 800; }
  .pat-root small { font-size: 11px; opacity: 0.9; }
  .pat-root code { color: #fff; background: rgba(255, 255, 255, 0.18); padding: 0 5px; border-radius: 5px; }
  .pat-root::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -22px;
    width: 0;
    height: 22px;
    border-left: 1.5px dashed var(--color-border-tertiary);
  }

  .pat-cats {
    display: flex;
    align-items: flex-start;
    gap: 28px;
    padding-top: 22px;
    border-top: 1.5px dashed var(--color-border-tertiary);
    margin-top: 22px;
  }
  .pat-cat { display: flex; flex-direction: column; align-items: center; gap: 14px; position: relative; }
  .pat-cat::before {
    content: '';
    position: absolute;
    top: -22px;
    left: 50%;
    width: 0;
    height: 22px;
    border-left: 1.5px dashed var(--color-border-tertiary);
  }
  .pat-cat-head {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 10px;
    background: var(--c);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 6px 16px color-mix(in srgb, var(--c) 30%, transparent);
  }

  .pat-cards { display: flex; flex-direction: column; gap: 8px; width: 230px; }
  .pat-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    width: 100%;
    padding: 11px 12px 11px 16px;
    background: var(--color-bg-glass-darker);
    border: 1px solid var(--color-border);
    border-radius: 9px;
    box-shadow: var(--shadow-soft);
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    font-family: var(--font-sans);
    text-align: center;
  }
  .pat-card::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 10px;
    bottom: 10px;
    width: 3px;
    border-radius: 2px;
    background: var(--c);
  }
  .pat-card:hover,
  .pat-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
    border-color: color-mix(in srgb, var(--c) 40%, var(--color-border));
    outline: none;
  }
  .pat-card-name { font-size: 13px; font-weight: 700; color: var(--c); line-height: 1.2; }
  .pat-card-sub { font-size: 10.5px; font-weight: 600; color: var(--color-text-tertiary); line-height: 1.3; }

  @media (max-width: 768px) {
    .pat-cats { gap: 18px; }
    .pat-cards { width: 188px; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    (window as any).showPatGroup = function (group: string, btn: HTMLElement) {
      document.querySelectorAll('.tab').forEach((t) => t.classList.remove('on'));
      btn.classList.add('on');
      document.querySelectorAll<HTMLElement>('.pat-cat').forEach((cat) => {
        const show = group === 'all' || cat.dataset.group === group;
        cat.style.display = show ? '' : 'none';
      });
    };

    const infoPanel = document.getElementById('info');
    document.querySelectorAll<HTMLElement>('.pat-card').forEach((card) => {
      card.addEventListener('click', () => {
        const d = card.dataset;
        const color = d.color || '#1F618D';
        if (!infoPanel) return;
        infoPanel.innerHTML = `
          <div class="rc" style="animation: rcFadeIn 0.35s ease both;">
            <div class="rc__head">
              <div class="rc__icon" style="background: ${color}; box-shadow: 0 6px 16px color-mix(in srgb, ${color} 35%, transparent);"><i class="fa-solid fa-user"></i></div>
              <div class="rc__headtext">
                <h3 class="rc__title">${d.name ?? ''}</h3>
                <div class="rc__status"><div class="rc__status-dot" style="background:${color}"></div>Patient · ${d.catlabel ?? ''}</div>
              </div>
            </div>
            <div class="rc__section">
              <div class="rc__section-ic"><i class="fa-solid fa-circle-info"></i></div>
              <h4>Detail</h4>
            </div>
            <div class="rc__fields">
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-tag"></i> Poin</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val">${d.name ?? ''}</div>
              </div>
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-bookmark"></i> Ringkas</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val">${d.sub ?? ''}</div>
              </div>
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-circle-info"></i> Keterangan</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val rc-field__val--solo">${d.desc ?? ''}</div>
              </div>
            </div>
          </div>
        `;
        infoPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });
  });
</script>
