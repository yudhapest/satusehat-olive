---
import Layout from '../layouts/Layout.astro';
import docsData from '../data/practitioners.json';

interface Doc { name: string; spec: string; pid: string; }

const docs = docsData as Doc[];

const GROUP: Record<string, { label: string; color: string; icon: string }> = {
  umum: { label: 'Dokter Umum', color: '#1F618D', icon: 'fa-stethoscope' },
  dasar: { label: 'Spesialis Dasar', color: '#1E8449', icon: 'fa-user-doctor' },
  lain: { label: 'Spesialis Lain', color: '#6C3483', icon: 'fa-staff-snake' },
};

const SPEC_GROUP: Record<string, string> = {
  'Dokter Umum': 'umum',
  'Penyakit Dalam': 'dasar',
  'Anak': 'dasar',
  'Bedah': 'dasar',
  'Obstetri & Ginekologi': 'dasar',
};
const groupOf = (spec: string) => SPEC_GROUP[spec] ?? 'lain';

const TAB_ORDER = ['umum', 'dasar', 'lain'];
const groups = TAB_ORDER.map((key) => {
  const docsIn = docs.filter((d) => groupOf(d.spec) === key);
  const specs = [...new Set(docsIn.map((d) => d.spec))].sort((a, b) => a.localeCompare(b, 'id'));
  return {
    key,
    ...GROUP[key],
    specialties: specs.map((spec) => ({
      spec,
      docs: docsIn.filter((d) => d.spec === spec).sort((a, b) => a.name.localeCompare(b.name, 'id')),
    })),
  };
});

const total = docs.length;
const totalSpec = new Set(docs.map((d) => d.spec)).size;
const countByGroup = (key: string) => docs.filter((d) => groupOf(d.spec) === key).length;
---

<Layout title="Practitioner" pageTitle="Practitioner (Dokter)" icon="fa-user-doctor">
  <div class="wrap">
    <div class="tab-bar">
      <button class="tab on" onclick="showPracGroup('all', this)"><i class="fa-solid fa-border-all"></i> Semua</button>
      <button class="tab" onclick="showPracGroup('umum', this)"><i class="fa-solid fa-stethoscope"></i> Dokter Umum</button>
      <button class="tab" onclick="showPracGroup('dasar', this)"><i class="fa-solid fa-user-doctor"></i> Spesialis Dasar</button>
      <button class="tab" onclick="showPracGroup('lain', this)"><i class="fa-solid fa-staff-snake"></i> Spesialis Lain</button>
    </div>

    <div class="resource-summary-grid">
      <div class="summary-card"><strong>{total}</strong><span>Dokter terdaftar (Practitioner)</span></div>
      <div class="summary-card"><strong>{countByGroup('umum')}</strong><span>Dokter Umum</span></div>
      <div class="summary-card"><strong>{countByGroup('dasar') + countByGroup('lain')}</strong><span>Dokter Spesialis</span></div>
      <div class="summary-card"><strong>{totalSpec}</strong><span>Jenis spesialisasi</span></div>
    </div>

    <div class="scroll">
      <div class="prac-tree">
        <div class="prac-root">
          <i class="fa-solid fa-user-doctor"></i>
          <div>
            <strong>Practitioner Terdaftar di SATUSEHAT</strong>
            <small>Sumber: <code>_ref_dokter</code> · Total {total} dokter</small>
          </div>
        </div>

        <div class="prac-cats">
          {
            groups.map((g) => (
              <div class="prac-cat" data-group={g.key} style={`--c:${g.color}`}>
                <div class="prac-cat-head">
                  <i class={`fa-solid ${g.icon}`} /> {g.label}
                </div>
                <div class="prac-specs">
                  {g.specialties.map((s) => (
                    <div class="prac-spec">
                      <div class="prac-spec-head">
                        <span class="prac-spec-name">{s.spec}</span>
                        <span class="prac-spec-meta">{s.docs.length} dokter</span>
                      </div>
                      <div class="prac-cards">
                        {s.docs.map((doc) => (
                          <button
                            class="prac-card"
                            type="button"
                            data-name={doc.name}
                            data-spec={doc.spec}
                            data-pid={doc.pid}
                            data-color={g.color}
                            data-grouplabel={g.label}
                          >
                            <span class="prac-card-name">{doc.name}</span>
                            <span class="prac-card-sub">Practitioner: {doc.pid}</span>
                          </button>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="info" id="info">
      <span class="hint"><i class="fa-solid fa-hand-pointer"></i> Klik salah satu dokter untuk melihat spesialisasi dan Practitioner ID-nya. Nama &amp; ID disamarkan (<code>**</code> / <code>****</code>).</span>
    </div>
  </div>
</Layout>

<style>
  .prac-tree {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 100%;
    width: max-content;
  }

  .prac-root {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 22px;
    border-radius: 14px;
    background: linear-gradient(180deg, #C0392B, #97271b);
    color: #fff;
    box-shadow: 0 8px 22px rgba(192, 57, 43, 0.28);
    position: relative;
  }
  .prac-root i { font-size: 20px; opacity: 0.95; }
  .prac-root strong { display: block; font-size: 15px; font-weight: 800; }
  .prac-root small { font-size: 11px; opacity: 0.85; }
  .prac-root code { color: #fff; }
  .prac-root::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -22px;
    width: 0;
    height: 22px;
    border-left: 1.5px dashed var(--color-border-tertiary);
  }

  .prac-cats {
    display: flex;
    align-items: flex-start;
    gap: 28px;
    padding-top: 22px;
    border-top: 1.5px dashed var(--color-border-tertiary);
    margin-top: 22px;
  }
  .prac-cat { display: flex; flex-direction: column; align-items: center; gap: 14px; position: relative; }
  .prac-cat::before {
    content: '';
    position: absolute;
    top: -22px;
    left: 50%;
    width: 0;
    height: 22px;
    border-left: 1.5px dashed var(--color-border-tertiary);
  }
  .prac-cat-head {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 10px;
    background: var(--c);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 6px 16px color-mix(in srgb, var(--c) 30%, transparent);
  }

  .prac-specs { display: flex; align-items: flex-start; gap: 16px; }
  .prac-spec { display: flex; flex-direction: column; gap: 10px; width: 210px; }

  .prac-spec-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    padding: 9px 12px;
    border-radius: 9px;
    background: linear-gradient(180deg, var(--c), color-mix(in srgb, var(--c) 78%, #000));
    color: #fff;
    text-align: center;
    box-shadow: 0 5px 14px color-mix(in srgb, var(--c) 28%, transparent);
  }
  .prac-spec-name { font-size: 12.5px; font-weight: 800; line-height: 1.2; }
  .prac-spec-meta { font-size: 10px; opacity: 0.92; font-weight: 600; }

  .prac-cards { display: flex; flex-direction: column; gap: 8px; }
  .prac-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    width: 100%;
    padding: 8px 10px 8px 14px;
    background: var(--color-bg-glass-darker);
    border: 1px solid var(--color-border);
    border-radius: 9px;
    box-shadow: var(--shadow-soft);
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    font-family: var(--font-sans);
    text-align: center;
  }
  .prac-card::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 9px;
    bottom: 9px;
    width: 3px;
    border-radius: 2px;
    background: var(--c);
  }
  .prac-card:hover,
  .prac-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
    border-color: color-mix(in srgb, var(--c) 40%, var(--color-border));
    outline: none;
  }
  .prac-card-name {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--c);
    line-height: 1.2;
  }
  .prac-card-sub {
    font-size: 9.5px;
    font-weight: 600;
    color: var(--color-text-tertiary);
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .prac-cats { gap: 18px; }
    .prac-spec { width: 172px; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    (window as any).showPracGroup = function (group: string, btn: HTMLElement) {
      document.querySelectorAll('.tab').forEach((t) => t.classList.remove('on'));
      btn.classList.add('on');
      document.querySelectorAll<HTMLElement>('.prac-cat').forEach((cat) => {
        const show = group === 'all' || cat.dataset.group === group;
        cat.style.display = show ? '' : 'none';
      });
    };

    const infoPanel = document.getElementById('info');
    document.querySelectorAll<HTMLElement>('.prac-card').forEach((card) => {
      card.addEventListener('click', () => {
        const d = card.dataset;
        const color = d.color || '#1F618D';
        if (!infoPanel) return;
        infoPanel.innerHTML = `
          <div class="rc" style="animation: rcFadeIn 0.35s ease both;">
            <div class="rc__head">
              <div class="rc__icon" style="background: ${color}; box-shadow: 0 6px 16px color-mix(in srgb, ${color} 35%, transparent);"><i class="fa-solid fa-user-doctor"></i></div>
              <div class="rc__headtext">
                <h3 class="rc__title">${d.name ?? ''}</h3>
                <div class="rc__status"><div class="rc__status-dot" style="background:${color}"></div>Practitioner · ${d.grouplabel ?? ''}</div>
              </div>
            </div>
            <div class="rc__section">
              <div class="rc__section-ic"><i class="fa-solid fa-circle-info"></i></div>
              <h4>Detail Practitioner</h4>
            </div>
            <div class="rc__fields">
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-user-doctor"></i> Nama Dokter</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val">${d.name ?? ''}</div>
              </div>
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-stethoscope"></i> Spesialisasi</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val">${d.spec ?? ''}</div>
              </div>
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-fingerprint"></i> Practitioner ID</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val">${d.pid ?? ''}</div>
              </div>
              <div class="rc-field">
                <div class="rc-field__name"><i class="fa-solid fa-link"></i> Relasi FHIR</div>
                <span class="rc-field__sep">:</span>
                <div class="rc-field__val rc-field__val--solo">PractitionerRole / Encounter.participant → Practitioner</div>
              </div>
            </div>
          </div>
        `;
        infoPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });
  });
</script>
