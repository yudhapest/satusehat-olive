window.showPhase = function(m,btn){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  if (btn) btn.classList.add('on');
  else if (event && event.target && event.target.classList.contains('tab')) event.target.classList.add('on');

  document.querySelectorAll('.rn').forEach(el=>{
    const targetPhase = arguments[0];
    const elPhase = el.dataset.phase || el.dataset.mod;
    if(targetPhase === 'all' || elPhase === targetPhase) {
      el.style.opacity = '1';
      el.style.pointerEvents = 'auto';
    } else {
      el.style.opacity = '0.08';
      el.style.pointerEvents = 'none';
    }
  });

  const phase = arguments[0];
  if (phase !== 'all') {
    const firstEl = document.querySelector(`.rn[data-phase="${phase}"]`) || document.querySelector(`.rn[data-mod="${phase}"]`);
    if (firstEl) {
      firstEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  } else {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
}
