---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Questionnaire" pageTitle="Questionnaire" icon="fa-list-check">
  <div class="wrap">
  <div class="header">
    <h2><i class="fa-solid fa-list-check" style="color: #C0392B;"></i> QuestionnaireResponse — Posisi di Rajal, IGD &amp; Ranap + Penanggung Jawab</h2>
    <div class="sub">Resource ini wajib ada di ketiga modul. Klik tiap QR untuk detail field &amp; PIC pengisian.</div>
  </div>

  <div class="tab-bar">
    <button class="tab on" onclick="showPhase('all',this)"><i class="fa-solid fa-border-all"></i> Semua Modul</button>
    <button class="tab" onclick="showPhase('rajal',this)"><i class="fa-solid fa-hospital-user"></i> Rajal</button>
    <button class="tab" onclick="showPhase('igd',this)"><i class="fa-solid fa-truck-medical"></i> IGD</button>
    <button class="tab" onclick="showPhase('ranap',this)"><i class="fa-solid fa-bed-pulse"></i> Ranap</button>
  </div>

  <div class="scroll">
  <svg id="svg" width="1060" viewBox="0 0 1060 1820" role="img">
    <title>Posisi QuestionnaireResponse di Rajal IGD Ranap</title>
    <defs>
      <marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
        <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </marker>
    </defs>

    <!-- ============================================================ -->
    <!-- MODUL RAJAL -->
    <!-- ============================================================ -->
    <!-- Aktor: Pendaftaran=100, Perawat=220, Dokter=340, Farmasi=460, AhliGizi=570, Apoteker=680, SS=880 -->

    <rect x="8" y="8" width="1044" height="22" rx="4" fill="#1F618D" opacity=".14"/>
    <text x="14" y="23" font-size="11" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">MODUL RAWAT JALAN (RAJAL) — Posisi QuestionnaireResponse</text>

    <!-- Actor boxes -->
    <rect x="52" y="36" width="90" height="34" rx="6" fill="#1F618D"/>
    <text x="97" y="55" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Pendaftaran</text>
    <rect x="172" y="36" width="90" height="34" rx="6" fill="#1E8449"/>
    <text x="217" y="51" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Perawat</text>
    <text x="217" y="63" text-anchor="middle" font-size="8" fill="#A9DFBF" font-family="var(--font-sans)">(Poli)</text>
    <rect x="292" y="36" width="90" height="34" rx="6" fill="#6C3483"/>
    <text x="337" y="55" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Dokter (Poli)</text>
    <rect x="412" y="36" width="90" height="34" rx="6" fill="#117A65"/>
    <text x="457" y="51" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Farmasi</text>
    <text x="457" y="63" text-anchor="middle" font-size="8" fill="#A2D9CE" font-family="var(--font-sans)">(Apoteker)</text>
    <rect x="532" y="36" width="90" height="34" rx="6" fill="#1A5276"/>
    <text x="577" y="51" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Ahli Gizi</text>
    <text x="577" y="63" text-anchor="middle" font-size="8" fill="#AED6F1" font-family="var(--font-sans)">(Dietisien)</text>
    <rect x="800" y="36" width="240" height="34" rx="6" fill="#C0392B"/>
    <text x="920" y="55" text-anchor="middle" font-size="10" font-weight="500" fill="#fff" font-family="var(--font-sans)">SATUSEHAT Platform</text>

    <!-- Lifelines rajal -->
    <line x1="97"  y1="70" x2="97"  y2="380" stroke="#1F618D" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="217" y1="70" x2="217" y2="380" stroke="#1E8449" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="337" y1="70" x2="337" y2="380" stroke="#6C3483" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="457" y1="70" x2="457" y2="380" stroke="#117A65" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="577" y1="70" x2="577" y2="380" stroke="#1A5276" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="920" y1="70" x2="920" y2="380" stroke="#C0392B" stroke-width="1" stroke-dasharray="3 4" opacity=".25"/>

    <!-- Encounter Rajal (konteks) -->
    <rect x="60" y="78" width="970" height="32" rx="4" fill="#4A90D9" opacity=".08" stroke="#4A90D9" stroke-width="1" stroke-opacity=".4"/>
    <text x="68" y="94" font-size="10" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">Encounter (AMB, arrived→finished) — anchor semua resource rajal</text>
    <line x1="97" y1="110" x2="912" y2="110" stroke="#4A90D9" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".5"/>

    <!-- QR 1: Skrining Gizi Rajal -->
    <g class="rn" data-id="qr_gizi_rajal" data-mod="rajal" style="cursor:pointer">
      <rect x="175" y="118" width="830" height="46" rx="5" fill="#1A5276" opacity=".1" stroke="#1A5276" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="183" y="135" font-size="11" font-weight="500" fill="#1A5276" font-family="var(--font-sans)">QR-1 Rajal: Skrining Gizi (MNA / MUST / STRONG-kids)</text>
      <text x="183" y="150" font-size="10" fill="#154360" font-family="var(--font-sans)">PIC: Ahli Gizi / Dietisien | dilakukan saat asesmen awal perawat atau rujuk ke poli gizi</text>
      <rect x="895" y="124" width="86" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="938" y="135" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL*</text>
      <line x1="577" y1="164" x2="912" y2="164" stroke="#1A5276" stroke-width="1.3" marker-end="url(#ar)" stroke-dasharray="4 3"/>
      <text x="745" y="160" text-anchor="middle" font-size="9" fill="#1A5276" font-family="var(--font-sans)">POST /QuestionnaireResponse (gizi)</text>
    </g>

    <!-- QR 2: Skrining Batuk Rajal -->
    <g class="rn" data-id="qr_batuk_rajal" data-mod="rajal" style="cursor:pointer">
      <rect x="175" y="172" width="830" height="46" rx="5" fill="#1E8449" opacity=".1" stroke="#1E8449" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="183" y="189" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">QR-2 Rajal: Skrining Batuk / TB</text>
      <text x="183" y="204" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">PIC: Perawat Poli | dilakukan saat asesmen awal, sebelum masuk ruang periksa dokter</text>
      <rect x="895" y="178" width="86" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="938" y="189" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL*</text>
      <line x1="217" y1="218" x2="912" y2="218" stroke="#1E8449" stroke-width="1.3" marker-end="url(#ar)" stroke-dasharray="4 3"/>
      <text x="565" y="214" text-anchor="middle" font-size="9" fill="#1E8449" font-family="var(--font-sans)">POST /QuestionnaireResponse (batuk)</text>
    </g>

    <!-- QR 3: Pengkajian Resep Rajal -->
    <g class="rn" data-id="qr_resep_rajal" data-mod="rajal" style="cursor:pointer">
      <rect x="415" y="226" width="590" height="46" rx="5" fill="#117A65" opacity=".1" stroke="#117A65" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="423" y="243" font-size="11" font-weight="500" fill="#117A65" font-family="var(--font-sans)">QR-3 Rajal: Pengkajian Resep (Administratif + Farmasetik + Klinis)</text>
      <text x="423" y="258" font-size="10" fill="#0E6655" font-family="var(--font-sans)">PIC: Apoteker / TTK | dilakukan setelah MedicationRequest diterima farmasi</text>
      <rect x="895" y="232" width="86" height="14" rx="3" fill="#C0392B" opacity=".18"/>
      <text x="938" y="243" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB*</text>
      <line x1="457" y1="272" x2="912" y2="272" stroke="#117A65" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="685" y="268" text-anchor="middle" font-size="9" fill="#117A65" font-family="var(--font-sans)">POST /QuestionnaireResponse (kajian resep) — basedOn: MedicationRequest</text>
    </g>

    <!-- Note rajal -->
    <rect x="60" y="282" width="970" height="90" rx="5" fill="none" stroke="var(--color-border-tertiary)" stroke-width=".8"/>
    <text x="70" y="298" font-size="9" font-weight="500" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Catatan Rajal: * WAJIB jika fasyankes menerbitkan resep (kajian resep wajib sesuai Permenkes 72/2016 tentang Standar Pelayanan Kefarmasian di RS)</text>
    <text x="70" y="312" font-size="9" fill="var(--color-text-tertiary)" font-family="var(--font-sans)">* Skrining gizi &amp; batuk OPSIONAL secara teknis SATUSEHAT, tapi WAJIB secara standar akreditasi SNARS (berlaku di RS terakreditasi)</text>
    <text x="70" y="326" font-size="9" fill="var(--color-text-tertiary)" font-family="var(--font-sans)">Urutan di Rajal: Encounter → Skrining Batuk (QR) → Asesmen Perawat → Skrining Gizi (QR, jika ada rujukan gizi) → Dokter periksa → MedicationRequest → Kajian Resep (QR) → MedicationDispense → Encounter finished</text>
    <text x="70" y="340" font-size="9" fill="#C0392B" font-family="var(--font-sans)">PIC Ringkas: Skrining batuk = Perawat | Skrining gizi = Ahli Gizi/Dietisien | Kajian resep = Apoteker</text>
    <text x="70" y="356" font-size="9" fill="var(--color-text-tertiary)" font-family="var(--font-sans)">Semua QuestionnaireResponse wajib mencantumkan: encounter (Encounter ID), author (PIC yang mengisi), questionnaire (URL kuesioner SATUSEHAT)</text>

    <!-- ============================================================ -->
    <!-- MODUL IGD -->
    <!-- ============================================================ -->
    <rect x="8" y="390" width="1044" height="22" rx="4" fill="#922B21" opacity=".14"/>
    <text x="14" y="405" font-size="11" font-weight="500" fill="#922B21" font-family="var(--font-sans)">MODUL IGD — Posisi QuestionnaireResponse</text>

    <!-- Actor boxes IGD -->
    <rect x="52" y="418" width="90" height="34" rx="6" fill="#922B21"/>
    <text x="97" y="433" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Triase IGD</text>
    <text x="97" y="445" text-anchor="middle" font-size="8" fill="#F1948A" font-family="var(--font-sans)">(Perawat Triase)</text>
    <rect x="172" y="418" width="90" height="34" rx="6" fill="#1E8449"/>
    <text x="217" y="433" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Perawat IGD</text>
    <text x="217" y="445" text-anchor="middle" font-size="8" fill="#A9DFBF" font-family="var(--font-sans)">(Ruang Tindakan)</text>
    <rect x="292" y="418" width="90" height="34" rx="6" fill="#6C3483"/>
    <text x="337" y="433" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Dokter IGD</text>
    <text x="337" y="445" text-anchor="middle" font-size="8" fill="#D7BDE2" font-family="var(--font-sans)">(Jaga/Spesialis)</text>
    <rect x="412" y="418" width="90" height="34" rx="6" fill="#117A65"/>
    <text x="457" y="433" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Farmasi IGD</text>
    <text x="457" y="445" text-anchor="middle" font-size="8" fill="#A2D9CE" font-family="var(--font-sans)">(Depo IGD)</text>
    <rect x="532" y="418" width="90" height="34" rx="6" fill="#1A5276"/>
    <text x="577" y="433" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Ahli Gizi</text>
    <text x="577" y="445" text-anchor="middle" font-size="8" fill="#AED6F1" font-family="var(--font-sans)">(On-call)</text>
    <rect x="800" y="418" width="240" height="34" rx="6" fill="#C0392B"/>
    <text x="920" y="437" text-anchor="middle" font-size="10" font-weight="500" fill="#fff" font-family="var(--font-sans)">SATUSEHAT Platform</text>

    <!-- Lifelines IGD -->
    <line x1="97"  y1="452" x2="97"  y2="730" stroke="#922B21" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="217" y1="452" x2="217" y2="730" stroke="#1E8449" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="337" y1="452" x2="337" y2="730" stroke="#6C3483" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="457" y1="452" x2="457" y2="730" stroke="#117A65" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="577" y1="452" x2="577" y2="730" stroke="#1A5276" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
    <line x1="920" y1="452" x2="920" y2="730" stroke="#C0392B" stroke-width="1" stroke-dasharray="3 4" opacity=".25"/>

    <!-- Encounter IGD konteks -->
    <rect x="60" y="460" width="970" height="32" rx="4" fill="#E74C3C" opacity=".07" stroke="#E74C3C" stroke-width="1" stroke-opacity=".4"/>
    <text x="68" y="476" font-size="10" font-weight="500" fill="#922B21" font-family="var(--font-sans)">Encounter (EMER, arrived→in-progress→finished) — anchor semua resource IGD</text>
    <line x1="97" y1="492" x2="912" y2="492" stroke="#E74C3C" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".5"/>

    <!-- QR IGD 1: Skrining Batuk (WAJIB di IGD) -->
    <g class="rn" data-id="qr_batuk_igd" data-mod="igd" style="cursor:pointer">
      <rect x="60" y="500" width="960" height="46" rx="5" fill="#E74C3C" opacity=".11" stroke="#E74C3C" stroke-width="1.3" stroke-opacity=".55"/>
      <text x="68" y="517" font-size="11" font-weight="500" fill="#922B21" font-family="var(--font-sans)">QR-1 IGD: Skrining Batuk / TB (Langsung saat Triase)</text>
      <text x="68" y="532" font-size="10" fill="#7B241C" font-family="var(--font-sans)">PIC: Perawat Triase | dilakukan bersamaan dengan pengkajian triase — sebelum pasien masuk ruang tindakan</text>
      <rect x="895" y="506" width="86" height="14" rx="3" fill="#C0392B" opacity=".18"/>
      <text x="938" y="517" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB*</text>
      <line x1="97" y1="546" x2="912" y2="546" stroke="#E74C3C" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="505" y="542" text-anchor="middle" font-size="9" fill="#E74C3C" font-family="var(--font-sans)">POST /QuestionnaireResponse (batuk) — bersamaan atau segera setelah ClinicalImpression triase</text>
    </g>

    <!-- QR IGD 2: Skrining Gizi -->
    <g class="rn" data-id="qr_gizi_igd" data-mod="igd" style="cursor:pointer">
      <rect x="535" y="554" width="485" height="46" rx="5" fill="#1A5276" opacity=".1" stroke="#1A5276" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="543" y="571" font-size="11" font-weight="500" fill="#1A5276" font-family="var(--font-sans)">QR-2 IGD: Skrining Gizi</text>
      <text x="543" y="586" font-size="10" fill="#154360" font-family="var(--font-sans)">PIC: Ahli Gizi on-call / Perawat IGD | dilakukan setelah kondisi pasien stabil</text>
      <rect x="895" y="560" width="86" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="938" y="571" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="577" y1="600" x2="912" y2="600" stroke="#1A5276" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="4 3"/>
      <text x="745" y="596" text-anchor="middle" font-size="9" fill="#1A5276" font-family="var(--font-sans)">POST /QuestionnaireResponse (gizi)</text>
    </g>

    <!-- QR IGD 3: Pengkajian Resep Cito -->
    <g class="rn" data-id="qr_resep_igd" data-mod="igd" style="cursor:pointer">
      <rect x="415" y="608" width="605" height="46" rx="5" fill="#117A65" opacity=".1" stroke="#117A65" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="423" y="625" font-size="11" font-weight="500" fill="#117A65" font-family="var(--font-sans)">QR-3 IGD: Pengkajian Resep Cito (Kajian Farmasi Darurat)</text>
      <text x="423" y="640" font-size="10" fill="#0E6655" font-family="var(--font-sans)">PIC: Apoteker Depo IGD | dilakukan segera setelah MedicationRequest priority urgent diterima</text>
      <rect x="895" y="614" width="86" height="14" rx="3" fill="#C0392B" opacity=".18"/>
      <text x="938" y="625" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB*</text>
      <line x1="457" y1="654" x2="912" y2="654" stroke="#117A65" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="685" y="650" text-anchor="middle" font-size="9" fill="#117A65" font-family="var(--font-sans)">POST /QuestionnaireResponse — basedOn: MedicationRequest (cito)</text>
    </g>

    <!-- Note IGD -->
    <rect x="60" y="664" width="970" height="58" rx="5" fill="none" stroke="var(--color-border-tertiary)" stroke-width=".8"/>
    <text x="70" y="680" font-size="9" font-weight="500" fill="#922B21" font-family="var(--font-sans)">⚠️ IGD Khusus: Skrining Batuk WAJIB segera saat triase (pasien batuk di IGD berpotensi TB/menular). Jangan tunggu kondisi stabil.</text>
    <text x="70" y="694" font-size="9" fill="var(--color-text-tertiary)" font-family="var(--font-sans)">Urutan IGD: Encounter(EMER) → ClinicalImpression triase + QR Batuk (bersamaan) → Obs vital → AllergyIntolerance → ... → MedicationRequest → QR Kajian Resep → MedicationDispense → Encounter finished</text>
    <text x="70" y="708" font-size="9" fill="#C0392B" font-family="var(--font-sans)">PIC: Skrining batuk = Perawat Triase | Skrining gizi = Ahli Gizi on-call (setelah stabil) | Kajian resep cito = Apoteker Depo IGD</text>

    <!-- ============================================================ -->
    <!-- MODUL RANAP -->
    <!-- ============================================================ -->
    <rect x="8" y="742" width="1044" height="22" rx="4" fill="#6C3483" opacity=".14"/>
    <text x="14" y="757" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">MODUL RAWAT INAP (RANAP) — Posisi QuestionnaireResponse</text>

    <!-- Actor boxes Ranap -->
    <rect x="52" y="770" width="90" height="34" rx="6" fill="#1F618D"/>
    <text x="97" y="785" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Admisi</text>
    <text x="97" y="797" text-anchor="middle" font-size="8" fill="#AED6F1" font-family="var(--font-sans)">(Pendaftaran)</text>
    <rect x="172" y="770" width="90" height="34" rx="6" fill="#1E8449"/>
    <text x="217" y="785" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Perawat</text>
    <text x="217" y="797" text-anchor="middle" font-size="8" fill="#A9DFBF" font-family="var(--font-sans)">(Bangsal)</text>
    <rect x="292" y="770" width="90" height="34" rx="6" fill="#6C3483"/>
    <text x="337" y="785" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">DPJP</text>
    <text x="337" y="797" text-anchor="middle" font-size="8" fill="#D7BDE2" font-family="var(--font-sans)">(Dokter)</text>
    <rect x="412" y="770" width="90" height="34" rx="6" fill="#117A65"/>
    <text x="457" y="785" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Apoteker</text>
    <text x="457" y="797" text-anchor="middle" font-size="8" fill="#A2D9CE" font-family="var(--font-sans)">(Depo Ranap)</text>
    <rect x="532" y="770" width="90" height="34" rx="6" fill="#1A5276"/>
    <text x="577" y="785" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Ahli Gizi</text>
    <text x="577" y="797" text-anchor="middle" font-size="8" fill="#AED6F1" font-family="var(--font-sans)">(Dietisien)</text>
    <rect x="652" y="770" width="90" height="34" rx="6" fill="#7B241C"/>
    <text x="697" y="785" text-anchor="middle" font-size="9" font-weight="500" fill="#fff" font-family="var(--font-sans)">Spesialis Lain</text>
    <text x="697" y="797" text-anchor="middle" font-size="8" fill="#F1948A" font-family="var(--font-sans)">(Konsultan)</text>
    <rect x="800" y="770" width="240" height="34" rx="6" fill="#C0392B"/>
    <text x="920" y="789" text-anchor="middle" font-size="10" font-weight="500" fill="#fff" font-family="var(--font-sans)">SATUSEHAT Platform</text>

    <!-- Lifelines Ranap -->
    <line x1="97"  y1="804" x2="97"  y2="1590" stroke="#1F618D" stroke-width=".7" stroke-dasharray="3 4" opacity=".2"/>
