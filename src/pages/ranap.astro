// Tambahkan animasi ke semua garis putus-putus (dashed lines)
document.querySelectorAll('line[stroke-dasharray]').forEach(line => {
  line.classList.add('animated-line');
});

attachResourceCards(D);

window.showPhase = function(p,btn){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('.rn').forEach(el=>{
    if(p==='all' || el.dataset.phase===p) {
      el.style.opacity = '1';
      el.style.pointerEvents = 'auto';
    } else {
      el.style.opacity = '0.08';
      el.style.pointerEvents = 'none';
    }
  });
}
  });
