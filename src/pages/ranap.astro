---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rawat Inap (Ranap)" pageTitle="Rawat Inap (Ranap)" icon="fa-bed-pulse">
  <div class="wrap">
  <div class="header">
    <h2><i class="fa-solid fa-bed-pulse" style="color: #C0392B;"></i> Alur SATUSEHAT Rawat Inap (Ranap) — Lengkap &amp; Terpisah per Aktor</h2>
    <div class="sub">Klik resource untuk detail implementasi · Gunakan tab untuk fokus per fase</div>
  </div>

  <div class="tab-bar">
    <button class="tab on" onclick="showPhase('all',this)"><i class="fa-solid fa-border-all"></i> Semua</button>
    <button class="tab" onclick="showPhase('admisi',this)"><i class="fa-solid fa-hospital-user"></i> Admisi</button>
    <button class="tab" onclick="showPhase('asesmen',this)"><i class="fa-solid fa-stethoscope"></i> Asesmen Awal</button>
    <button class="tab" onclick="showPhase('harian',this)"><i class="fa-solid fa-calendar-day"></i> Perawatan Harian</button>
    <button class="tab" onclick="showPhase('farmasi',this)"><i class="fa-solid fa-pills"></i> Farmasi</button>
    <button class="tab" onclick="showPhase('lab',this)"><i class="fa-solid fa-flask-vial"></i> Laboratorium</button>
    <button class="tab" onclick="showPhase('radiologi',this)"><i class="fa-solid fa-x-ray"></i> Radiologi</button>
    <button class="tab" onclick="showPhase('mutasi',this)"><i class="fa-solid fa-bed"></i> Mutasi Bed</button>
    <button class="tab" onclick="showPhase('discharge',this)"><i class="fa-solid fa-person-walking-arrow-right"></i> Discharge</button>
  </div>

  <div class="legend">
    <div class="leg"><div class="leg-dot pulse" style="background:#1F618D"></div>Admisi/Loket</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#1E8449"></div>Perawat Bangsal</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#6C3483"></div>DPJP/Dokter</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#117A65"></div>Farmasi</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#1A5276"></div>Laboratorium</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#7B241C"></div>Radiologi</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#C0392B"></div>Wajib</div>
    <div class="leg"><div class="leg-dot" style="background:#888"></div>Opsional</div>
    <div class="leg"><div class="leg-dot pulse" style="background:#E67E22"></div>Loop/Berkala</div>
  </div>

  <div class="scroll">
  <svg id="svg" width="1100" viewBox="0 0 1100 2260" role="img">
    <title>Alur integrasi SATUSEHAT rawat inap lengkap</title>
    <desc>Sequence diagram FHIR resource SATUSEHAT untuk rawat inap dengan aktor: Pasien, Admisi, Perawat Bangsal, DPJP, Farmasi, Laboratorium, Radiologi, SATUSEHAT</desc>
    <defs>
      <marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
        <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </marker>
    </defs>

    <!-- ===== ACTOR HEADERS =====
    centers: Pasien=55, Admisi=165, Perawat=278, Dokter=388, Farmasi=505, Lab=620, Radiologi=733, SS=960 -->
    <rect x="10" y="8" width="88" height="38" rx="7" fill="#2C3E50"/>
    <text x="54" y="31" text-anchor="middle" font-size="11" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Pasien /</text>
    <text x="54" y="43" text-anchor="middle" font-size="10" fill="#BDC3C7" font-family="var(--font-sans)">Keluarga</text>

    <rect x="114" y="8" width="100" height="38" rx="7" fill="#1F618D"/>
    <text x="164" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Admisi / Loket</text>
    <text x="164" y="40" text-anchor="middle" font-size="9" fill="#AED6F1" font-family="var(--font-sans)">(Pendaftaran Ranap)</text>

    <rect x="228" y="8" width="100" height="38" rx="7" fill="#1E8449"/>
    <text x="278" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Perawat</text>
    <text x="278" y="40" text-anchor="middle" font-size="9" fill="#A9DFBF" font-family="var(--font-sans)">(Bangsal/Ruangan)</text>

    <rect x="342" y="8" width="92" height="38" rx="7" fill="#6C3483"/>
    <text x="388" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">DPJP / Dokter</text>
    <text x="388" y="40" text-anchor="middle" font-size="9" fill="#D7BDE2" font-family="var(--font-sans)">(Visite &amp; Order)</text>

    <rect x="458" y="8" width="94" height="38" rx="7" fill="#117A65"/>
    <text x="505" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Farmasi</text>
    <text x="505" y="40" text-anchor="middle" font-size="9" fill="#A2D9CE" font-family="var(--font-sans)">(Depo/Apotek)</text>

    <rect x="572" y="8" width="96" height="38" rx="7" fill="#1A5276"/>
    <text x="620" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Laboratorium</text>
    <text x="620" y="40" text-anchor="middle" font-size="9" fill="#AED6F1" font-family="var(--font-sans)">(Lab Klinik)</text>

    <rect x="682" y="8" width="102" height="38" rx="7" fill="#7B241C"/>
    <text x="733" y="26" text-anchor="middle" font-size="10" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">Radiologi</text>
    <text x="733" y="40" text-anchor="middle" font-size="9" fill="#F1948A" font-family="var(--font-sans)">(RIS/PACS/DICOM)</text>

    <rect x="848" y="8" width="230" height="38" rx="7" fill="#C0392B"/>
    <text x="963" y="24" text-anchor="middle" font-size="11" font-weight="500" fill="#ECF0F1" font-family="var(--font-sans)">SATUSEHAT Platform</text>
    <text x="963" y="38" text-anchor="middle" font-size="9" fill="#F1948A" font-family="var(--font-sans)">+ NIDR (National Imaging Data Repository)</text>

    <!-- Lifelines -->
    <line x1="54"  y1="46" x2="54"  y2="2250" stroke="#2C3E50" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="164" y1="46" x2="164" y2="2250" stroke="#1F618D" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="278" y1="46" x2="278" y2="2250" stroke="#1E8449" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="388" y1="46" x2="388" y2="2250" stroke="#6C3483" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="505" y1="46" x2="505" y2="2250" stroke="#117A65" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="620" y1="46" x2="620" y2="2250" stroke="#1A5276" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="733" y1="46" x2="733" y2="2250" stroke="#7B241C" stroke-width=".7" stroke-dasharray="3 4" opacity=".22"/>
    <line x1="963" y1="46" x2="963" y2="2250" stroke="#C0392B" stroke-width="1.1" stroke-dasharray="3 4" opacity=".28"/>

    <!-- ===== FASE 1: ADMISI ===== -->
    <rect x="8" y="58" width="1080" height="19" rx="3" fill="#1F618D" opacity=".13"/>
    <text x="14" y="71" font-size="10" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">FASE 1 — Admisi &amp; Pendaftaran Rawat Inap</text>

    <text x="57" y="96" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Pasien masuk ranap</text>
    <line x1="54" y1="100" x2="157" y2="100" stroke="#1F618D" stroke-width="1.5" marker-end="url(#ar)"/>

    <!-- EpisodeOfCare -->
    <g class="rn" data-id="eoc" data-phase="admisi" style="cursor:pointer">
      <rect x="122" y="107" width="955" height="42" rx="5" fill="#4A90D9" opacity=".1" stroke="#4A90D9" stroke-width="1.1" stroke-opacity=".5" stroke-dasharray="5 3"/>
      <text x="131" y="123" font-size="11" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">0. EpisodeOfCare — Episode Perawatan (Opsional tapi Direkomendasikan)</text>
      <text x="131" y="138" font-size="10" fill="#2874A6" font-family="var(--font-sans)">Menghubungkan semua Encounter ranap dalam satu episode | status: active | managingOrganization</text>
      <rect x="930" y="113" width="64" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="962" y="124" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="164" y1="149" x2="954" y2="149" stroke="#4A90D9" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="4 3" stroke-opacity=".65"/>
      <text x="550" y="145" text-anchor="middle" font-size="9" fill="#4A90D9" font-family="var(--font-sans)">POST /EpisodeOfCare → simpan eoc-id</text>
    </g>

    <!-- Encounter Ranap -->
    <g class="rn" data-id="enc_ranap" data-phase="admisi" style="cursor:pointer">
      <rect x="122" y="160" width="955" height="44" rx="5" fill="#4A90D9" opacity=".14" stroke="#4A90D9" stroke-width="1.3" stroke-opacity=".6"/>
      <text x="131" y="177" font-size="11" font-weight="500" fill="#1F618D" font-family="var(--font-sans)">1. Encounter — Admisi Rawat Inap</text>
      <text x="131" y="192" font-size="10" fill="#2874A6" font-family="var(--font-sans)">status: in-progress | class: IMP | hospitalization.admitSource | location (kamar awal) | episodeOfCare</text>
      <rect x="938" y="166" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="961" y="177" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="164" y1="204" x2="954" y2="204" stroke="#4A90D9" stroke-width="1.5" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="550" y="200" text-anchor="middle" font-size="9" fill="#4A90D9" font-family="var(--font-sans)">POST /Encounter → simpan encounter-id (dipakai seluruh ranap)</text>
    </g>

    <!-- ===== FASE 2: ASESMEN AWAL ===== -->
    <rect x="8" y="220" width="1080" height="19" rx="3" fill="#1E8449" opacity=".13"/>
    <text x="14" y="233" font-size="10" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">FASE 2 — Asesmen Awal Perawat &amp; Dokter (dilakukan saat masuk)</text>

    <text x="167" y="255" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Asesmen awal masuk</text>
    <line x1="164" y1="259" x2="271" y2="259" stroke="#1E8449" stroke-width="1.5" marker-end="url(#ar)"/>

    <g class="rn" data-id="allergy_r" data-phase="asesmen" style="cursor:pointer">
      <rect x="236" y="265" width="841" height="42" rx="5" fill="#27AE60" opacity=".1" stroke="#27AE60" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="245" y="281" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">2. AllergyIntolerance — Riwayat Alergi</text>
      <text x="245" y="296" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Wajib diisi saat asesmen awal masuk | NKA jika tidak ada alergi | code SNOMED</text>
      <rect x="938" y="271" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="961" y="281" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="278" y1="307" x2="954" y2="307" stroke="#27AE60" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
    </g>

    <g class="rn" data-id="obs_masuk" data-phase="asesmen" style="cursor:pointer">
      <rect x="236" y="317" width="841" height="42" rx="5" fill="#27AE60" opacity=".1" stroke="#27AE60" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="245" y="333" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">3. Observation — Tanda Vital Saat Masuk</text>
      <text x="245" y="348" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Tensi, suhu, nadi, RR, SpO2, BB, TB | kode LOINC | 1 Obs per parameter</text>
      <rect x="938" y="323" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="961" y="333" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="278" y1="359" x2="954" y2="359" stroke="#27AE60" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="600" y="355" text-anchor="middle" font-size="9" fill="#27AE60" font-family="var(--font-sans)">POST /Observation (multiple)</text>
    </g>

    <g class="rn" data-id="cond_masuk" data-phase="asesmen" style="cursor:pointer">
      <rect x="236" y="368" width="841" height="42" rx="5" fill="#9B6BBE" opacity=".12" stroke="#9B6BBE" stroke-width="1.3" stroke-opacity=".55"/>
      <text x="245" y="384" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">4. Condition — Diagnosa Masuk (Diagnosis Kerja)</text>
      <text x="245" y="399" font-size="10" fill="#7D3C98" font-family="var(--font-sans)">ICD-10 wajib | clinicalStatus: active | use: admission diagnosis | dikirim SEBELUM Procedure</text>
      <rect x="938" y="374" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="961" y="384" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="388" y1="410" x2="954" y2="410" stroke="#9B6BBE" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="670" y="406" text-anchor="middle" font-size="9" fill="#9B6BBE" font-family="var(--font-sans)">POST /Condition → simpan condition-id</text>
    </g>

    <g class="rn" data-id="careplan" data-phase="asesmen" style="cursor:pointer">
      <rect x="236" y="419" width="841" height="42" rx="5" fill="#9B6BBE" opacity=".08" stroke="#9B6BBE" stroke-width="1" stroke-opacity=".4" stroke-dasharray="4 3"/>
      <text x="245" y="435" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">5. CarePlan — Rencana Perawatan &amp; Instruksi</text>
      <text x="245" y="450" font-size="10" fill="#7D3C98" font-family="var(--font-sans)">Rencana terapi, tindakan, lama rawat | instruksi medik &amp; keperawatan | activity list</text>
      <rect x="930" y="425" width="64" height="14" rx="3" fill="#888" opacity=".2"/>
      <text x="962" y="436" text-anchor="middle" font-size="9" fill="#666" font-weight="500" font-family="var(--font-sans)">OPSIONAL</text>
      <line x1="388" y1="461" x2="954" y2="461" stroke="#9B6BBE" stroke-width="1" marker-end="url(#ar)" stroke-dasharray="3 4" stroke-opacity=".55"/>
      <text x="670" y="457" text-anchor="middle" font-size="9" fill="#9B6BBE" font-family="var(--font-sans)" opacity=".7">POST /CarePlan → simpan careplan-id</text>
    </g>

    <!-- ===== FASE 3: LOOP PERAWATAN HARIAN ===== -->
    <rect x="8" y="477" width="1080" height="19" rx="3" fill="#E67E22" opacity=".15"/>
    <text x="14" y="490" font-size="10" font-weight="500" fill="#B7770D" font-family="var(--font-sans)">FASE 3 — Perawatan Harian (Loop: tiap hari / tiap shift)</text>

    <!-- Loop border -->
    <rect x="12" y="496" width="862" height="368" rx="6" fill="none" stroke="#E67E22" stroke-width="1.2" stroke-dasharray="6 4" opacity=".5"/>
    <text x="20" y="510" font-size="9" fill="#B7770D" font-family="var(--font-sans)">🔁 loop [Setiap Hari / Shift Perawatan]</text>

    <g class="rn" data-id="obs_harian" data-phase="harian" style="cursor:pointer">
      <rect x="236" y="516" width="620" height="42" rx="5" fill="#27AE60" opacity=".1" stroke="#27AE60" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="245" y="532" font-size="11" font-weight="500" fill="#1E8449" font-family="var(--font-sans)">6. Observation — Tanda Vital Berkala</text>
      <text x="245" y="547" font-size="10" fill="#1A7A42" font-family="var(--font-sans)">Tensi, suhu, nadi, RR, SpO2 tiap shift | skor nyeri, balance cairan | kode LOINC</text>
      <rect x="798" y="522" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="821" y="533" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="278" y1="558" x2="849" y2="558" stroke="#27AE60" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="560" y="554" text-anchor="middle" font-size="9" fill="#27AE60" font-family="var(--font-sans)">POST /Observation (tiap shift)</text>
    </g>

    <!-- MedicationRequest harian -->
    <g class="rn" data-id="medrq_ranap" data-phase="harian" style="cursor:pointer">
      <rect x="344" y="566" width="512" height="42" rx="5" fill="#1ABC9C" opacity=".1" stroke="#1ABC9C" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="353" y="582" font-size="11" font-weight="500" fill="#117A65" font-family="var(--font-sans)">7. MedicationRequest — Resep / Order Obat Harian</text>
      <text x="353" y="597" font-size="10" fill="#0E6655" font-family="var(--font-sans)">Obat injeksi / oral / infus | Medication di contained | route: IV/PO/IM | dosageInstruction</text>
      <rect x="798" y="572" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="821" y="582" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="388" y1="608" x2="849" y2="608" stroke="#1ABC9C" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="620" y="604" text-anchor="middle" font-size="9" fill="#1ABC9C" font-family="var(--font-sans)">POST /MedicationRequest</text>
    </g>

    <!-- MedicationDispense harian -->
    <g class="rn" data-id="meddisp_ranap" data-phase="harian" style="cursor:pointer">
      <rect x="344" y="616" width="512" height="42" rx="5" fill="#1ABC9C" opacity=".1" stroke="#1ABC9C" stroke-width="1.2" stroke-opacity=".5"/>
      <text x="353" y="632" font-size="11" font-weight="500" fill="#117A65" font-family="var(--font-sans)">8. MedicationDispense — Pemberian Obat ke Pasien</text>
      <text x="353" y="647" font-size="10" fill="#0E6655" font-family="var(--font-sans)">Diberikan oleh perawat/farmasi | status: completed | whenHandedOver per pemberian</text>
      <rect x="798" y="622" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="821" y="632" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="278" y1="658" x2="849" y2="658" stroke="#1ABC9C" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
      <text x="560" y="654" text-anchor="middle" font-size="9" fill="#1ABC9C" font-family="var(--font-sans)">POST /MedicationDispense (tiap pemberian)</text>
    </g>

    <!-- Visite Dokter -->
    <text x="391" y="678" font-size="10" fill="var(--color-text-secondary)" font-family="var(--font-sans)">Visite harian dokter</text>
    <line x1="388" y1="682" x2="281" y2="682" stroke="#6C3483" stroke-width="1.2" marker-end="url(#ar)" stroke-dasharray="3 3" stroke-opacity=".6"/>

    <g class="rn" data-id="cond_harian" data-phase="harian" style="cursor:pointer">
      <rect x="236" y="688" width="620" height="42" rx="5" fill="#9B6BBE" opacity=".12" stroke="#9B6BBE" stroke-width="1.2" stroke-opacity=".55"/>
      <text x="245" y="704" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">9. Condition — Update Diagnosa Harian</text>
      <text x="245" y="719" font-size="10" fill="#7D3C98" font-family="var(--font-sans)">Diagnosa baru/sekunder selama rawat | ICD-10 | gunakan POST baru per diagnosa baru</text>
      <rect x="798" y="694" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="821" y="704" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
      <line x1="388" y1="730" x2="849" y2="730" stroke="#9B6BBE" stroke-width="1.4" marker-end="url(#ar)" stroke-dasharray="5 3"/>
    </g>

    <g class="rn" data-id="proc_ranap" data-phase="harian" style="cursor:pointer">
      <rect x="236" y="738" width="620" height="42" rx="5" fill="#9B6BBE" opacity=".12" stroke="#9B6BBE" stroke-width="1.2" stroke-opacity=".55"/>
      <text x="245" y="754" font-size="11" font-weight="500" fill="#6C3483" font-family="var(--font-sans)">10. Procedure — Tindakan / Operasi</text>
      <text x="245" y="769" font-size="10" fill="#7D3C98" font-family="var(--font-sans)">ICD-9-CM | operasi, tindakan invasif, prosedur | reasonReference → Condition ID</text>
      <rect x="798" y="744" width="46" height="14" rx="3" fill="#C0392B" opacity=".2"/>
      <text x="821" y="754" text-anchor="middle" font-size="9" fill="#C0392B" font-weight="500" font-family="var(--font-sans)">WAJIB</text>
