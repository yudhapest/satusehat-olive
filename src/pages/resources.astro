      window.showResourceGroup = function(group, btn) {
        document.querySelectorAll('.tab').forEach((tab) => tab.classList.remove('on'));
        if (btn) btn.classList.add('on');

        document.querySelectorAll('.resource-section').forEach((section) => {
          const match = group === 'all' || section.dataset.group === group;
          section.style.display = match ? '' : 'none';
        });
      };
