            </div>
            <span class="sim-http sim-http--err">422</span>
          </div>
          <div class="sim-payload-error"><i class="fa-solid fa-circle-exclamation"></i> error_message: Invalid LOINC code 8310-9</div>
          <div class="sim-payload-grid">
