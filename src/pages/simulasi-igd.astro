const sourceMeta = (r: any) => {
  if (r.type === 'Patient') return { table: 'patient', id: 'P-001234' };
  if (r.type === 'Encounter') return { table: 'regpas', id: NOREG };
  if (r.type === 'ClinicalImpression') return { table: 'triase_igd', id: 'TRI-2201' };
  if (r.type === 'Observation') {
    if (['718-7', '6690-2', '777-3'].includes(r.obs)) return { table: 'hasil_lab', id: 'LAB-5501' };
    if (r.obs === '18782-3') return { table: 'bacaan_radiologi', id: 'RAD-5601' };
    return { table: 'vitalsign', id: 'VS-5501' };
  }
  if (r.type === 'AllergyIntolerance') return { table: 'alergi', id: 'ALG-001' };
  if (r.type === 'Condition') return { table: 'diagnosa', id: 'DX-1201' };
  if (r.type === 'Procedure') return { table: 'tindakan', id: 'PRC-7701' };
  if (r.type === 'MedicationRequest') return { table: 'resep', id: 'RX-3301' };
  if (r.type === 'MedicationDispense') return { table: 'penyerahan_obat', id: 'DSP-3301' };
  if (r.type === 'ServiceRequest') return r.ihs.includes('rad') ? { table: 'order_radiologi', id: 'SRR-9101' } : { table: 'order_lab', id: 'SRL-9001' };
  if (r.type === 'Specimen') return { table: 'spesimen_lab', id: 'SPC-4401' };
  if (r.type === 'DiagnosticReport') return r.ihs.includes('rad') ? { table: 'laporan_radiologi', id: 'DRR-6701' } : { table: 'laporan_lab', id: 'DRL-6601' };
  if (r.type === 'ImagingStudy') return { table: 'pacs', id: 'IMG-7001' };
  return { table: '—', id: '—' };
};

const resourceFromEndpoint = (endpoint: string) => endpoint.replace('/Encounter/enc-igd-2606060001', '/Encounter').replace(' (NIDR)', '').replace('/', '');
const jsonPreview = (d: any, type: 'request' | 'response') => {
  const resourceType = resourceFromEndpoint(d.ep);
  if (type === 'request') return `{"resourceType":"${resourceType}","...":"lihat payload lengkap"}`;
  if (d.err) return '{"resourceType":"OperationOutcome","issue":[...]}';
  return `{"resourceType":"${resourceType}","id":"${masterRows.find((r) => r.id === d.log)?.ihs || 'generated-id'}"}`;
};
