const ddlSql = `-- 1) Tabel master: 1 baris per resource (status terkini)
CREATE TABLE satusehat_log (
  id               BIGINT UNSIGNED   NOT NULL AUTO_INCREMENT,
  module           ENUM('igd','rajal','ranap') NOT NULL,
  resource_type    VARCHAR(50)       NOT NULL,
  noreg            VARCHAR(20)       NULL,   -- VARCHAR(12) → VARCHAR(20); NULL hanya untuk Patient
  source_table     VARCHAR(50)       NOT NULL,
  source_id        VARCHAR(20)       NOT NULL,
  observation_code VARCHAR(20)       NULL,
  encounter_status ENUM('arrived','in-progress','finished','cancelled') NULL,  -- VARCHAR → ENUM cegah typo
  status           ENUM('pending','retrying','sent','failed') NOT NULL DEFAULT 'pending',
  ihs_id           VARCHAR(100)      NULL,
  retry_count      TINYINT UNSIGNED  NOT NULL DEFAULT 0,   -- hitungan retry untuk RetryService (batas maksimal)
  last_error       VARCHAR(500)      NULL,                 -- ringkasan error terakhir (dashboard tanpa JOIN)
  sent_at          DATETIME          NULL,
  created_at       DATETIME          NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at       DATETIME          NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (id),
  INDEX idx_noreg_status    (noreg, status),
  INDEX idx_module_status   (module, status),
  INDEX idx_source          (source_table, source_id),
  INDEX idx_resource_lookup (noreg, resource_type),
  INDEX idx_status_retry    (status, retry_count)   -- RetryService: "failed AND retry_count < 3"
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- 2) Tabel detail: 1 baris per attempt + audit request/response (Opsi A)
CREATE TABLE satusehat_log_detail (
  id              BIGINT UNSIGNED   NOT NULL AUTO_INCREMENT,
  log_id          BIGINT UNSIGNED   NOT NULL,
  noreg           VARCHAR(20)       NULL,   -- redundan (= satusehat_log.noreg) → query tanpa JOIN
  attempt_no      SMALLINT UNSIGNED NOT NULL DEFAULT 1,
  http_method     VARCHAR(8)        NOT NULL,
  endpoint        VARCHAR(255)      NOT NULL,
  request_body    JSON              NULL,
  response_status SMALLINT UNSIGNED NULL,
  response_body   JSON              NULL,
  error_message   TEXT              NULL,
  duration_ms     INT UNSIGNED      NULL,
  triggered_by    VARCHAR(64)       NULL,
  created_at      DATETIME          NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (id),
  CONSTRAINT fk_detail_log FOREIGN KEY (log_id)
      REFERENCES satusehat_log(id) ON DELETE CASCADE,
  INDEX idx_log_attempt    (log_id, attempt_no),
  INDEX idx_noreg_detail   (noreg, created_at),   -- ganti idx_status_created: "semua attempt kunjungan X"
  INDEX idx_log_created    (log_id, created_at)    -- ambil attempt terbaru 1 log (ORDER BY created_at DESC)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;`;

const querySql = `-- Semua attempt + payload satu resource, urut percobaan
-- (log_id = 4 = Observation tekanan darah; lihat attempt 1 gagal lalu retry sukses)
SELECT attempt_no, http_method, endpoint, response_status,
       error_message, duration_ms, triggered_by, created_at
FROM   satusehat_log_detail
WHERE  log_id = 4
ORDER  BY attempt_no;

-- Ambil HANYA attempt terakhir tiap resource untuk satu kunjungan
SELECT l.resource_type, l.ihs_id, d.response_status, d.created_at
FROM   satusehat_log l
JOIN   satusehat_log_detail d ON d.log_id = l.id
WHERE  l.noreg = '2606060042'
  AND  d.attempt_no = (SELECT MAX(d2.attempt_no)
                       FROM satusehat_log_detail d2
                       WHERE d2.log_id = l.id);

-- RetryService: cari resource gagal yang masih boleh diretry (pakai idx_status_retry)
-- retry_count & last_error langsung dari master → tanpa JOIN ke tabel detail
SELECT id, resource_type, noreg, retry_count, last_error
FROM   satusehat_log
WHERE  status = 'failed' AND retry_count < 3
ORDER  BY updated_at;

-- Query ke dalam JSON (MySQL 8) — cari attempt dengan kode LOINC tertentu
SELECT id, log_id, response_status
FROM   satusehat_log_detail
WHERE  request_body->>'$.code.coding[0].code' = '55284-5';`;

