const sourceMeta = (r: any) => {
  if (r.type === 'Patient') return { table: 'patient', id: 'P-004277' };
  if (r.type === 'Encounter') return { table: 'regpas', id: NOREG };
  if (r.type === 'Observation') {
    if (['2951-2', '2823-3', '2075-0'].includes(r.obs)) return { table: 'hasil_lab', id: 'LAB-5820' };
    if (r.obs === '18782-3') return { table: 'bacaan_radiologi', id: 'RAD-5910' };
    return { table: 'vitalsign', id: 'VS-7781' };
  }
  if (r.type === 'AllergyIntolerance') return { table: 'alergi', id: 'ALG-441' };
  if (r.type === 'FamilyMemberHistory') return { table: 'riwayat_keluarga', id: 'FMH-220' };
  if (r.type === 'MedicationStatement') return { table: 'obat_rutin', id: 'MST-318' };
  if (r.type === 'ClinicalImpression') return { table: 'catatan_soap', id: 'SOAP-901' };
  if (r.type === 'Condition') return { table: 'diagnosa', id: 'DX-2042' };
  if (r.type === 'Procedure') return { table: 'tindakan', id: 'PRC-8810' };
  if (r.type === 'MedicationRequest') return { table: 'resep', id: 'RX-5520' };
  if (r.type === 'MedicationDispense') return { table: 'penyerahan_obat', id: 'DSP-5520' };
  if (r.type === 'ServiceRequest') return r.ihs.includes('rad') ? { table: 'order_radiologi', id: 'SRR-9401' } : { table: 'order_lab', id: 'SRL-9301' };
  if (r.type === 'Specimen') return { table: 'spesimen_lab', id: 'SPC-4710' };
  if (r.type === 'DiagnosticReport') return r.ihs.includes('rad') ? { table: 'laporan_radiologi', id: 'DRR-6930' } : { table: 'laporan_lab', id: 'DRL-6920' };
  if (r.type === 'ImagingStudy') return { table: 'pacs', id: 'IMG-7210' };
  return { table: '—', id: '—' };
};

const resourceFromEndpoint = (endpoint: string) => endpoint.replace('/Encounter/enc-rajal-2606060042', '/Encounter').replace(' (NIDR)', '').replace('/', '');
const jsonPreview = (d: any, type: 'request' | 'response') => {
  const resourceType = resourceFromEndpoint(d.ep);
  if (type === 'request') return `{"resourceType":"${resourceType}","...":"lihat payload lengkap"}`;
  if (d.err) return '{"resourceType":"OperationOutcome","issue":[...]}';
  return `{"resourceType":"${resourceType}","id":"${masterRows.find((r) => r.id === d.log)?.ihs || 'generated-id'}"}`;
};

