const sourceMeta = (r: any) => {
  if (r.type === 'Patient') return { table: 'patient', id: 'P-006108' };
  if (r.type === 'EpisodeOfCare') return { table: 'episode_perawatan', id: 'EOC-101' };
  if (r.type === 'Encounter') return { table: 'regpas', id: NOREG };
  if (r.type === 'Observation') {
    if (['718-7', '6690-2', '777-3'].includes(r.obs)) return { table: 'hasil_lab', id: 'LAB-6620' };
    if (r.obs === '18782-3') return { table: 'bacaan_radiologi', id: 'RAD-6610' };
    return { table: 'vitalsign', id: 'VS-9912' };
  }
  if (r.type === 'AllergyIntolerance') return { table: 'alergi', id: 'ALG-771' };
  if (r.type === 'CarePlan') return { table: 'rencana_asuhan', id: 'CP-540' };
  if (r.type === 'Condition') {
    if (r.ihs === 'cond-ranap-002') return { table: 'diagnosa_sekunder', id: 'DX-3311' };
    if (r.ihs === 'cond-ranap-003') return { table: 'diagnosa_pulang', id: 'DX-3399' };
    return { table: 'diagnosa', id: 'DX-3310' };
  }
  if (r.type === 'Procedure') return { table: 'tindakan', id: 'PRC-9920' };
  if (r.type === 'MedicationRequest') return { table: 'resep', id: 'RX-7710' };
  if (r.type === 'MedicationDispense') return r.ihs === 'meddisp-rn-002' ? { table: 'penyerahan_obat', id: 'DSP-7711' } : { table: 'penyerahan_obat', id: 'DSP-7710' };
  if (r.type === 'ServiceRequest') return r.ihs.includes('rad') ? { table: 'order_radiologi', id: 'SRR-9901' } : { table: 'order_lab', id: 'SRL-9801' };
  if (r.type === 'Specimen') return { table: 'spesimen_lab', id: 'SPC-5210' };
  if (r.type === 'DiagnosticReport') return r.ihs.includes('rad') ? { table: 'laporan_radiologi', id: 'DRR-7730' } : { table: 'laporan_lab', id: 'DRL-7720' };
  if (r.type === 'ImagingStudy') return { table: 'pacs', id: 'IMG-7810' };
  if (r.type === 'Composition') return { table: 'resume_medis', id: 'CMP-880' };
  return { table: '—', id: '—' };
};

const resourceFromEndpoint = (endpoint: string) => endpoint
  .replace('/Encounter/enc-ranap-2606060108', '/Encounter')
  .replace('/EpisodeOfCare/eoc-ranap-001', '/EpisodeOfCare')
  .replace(' (NIDR)', '')
  .replace('/', '');
const jsonPreview = (d: any, type: 'request' | 'response') => {
  const resourceType = resourceFromEndpoint(d.ep);
  if (type === 'request') return `{"resourceType":"${resourceType}","...":"lihat payload lengkap"}`;
  if (d.err) return '{"resourceType":"OperationOutcome","issue":[...]}';
  return `{"resourceType":"${resourceType}","id":"${masterRows.find((r) => r.id === d.log)?.ihs || 'generated-id'}"}`;
};
